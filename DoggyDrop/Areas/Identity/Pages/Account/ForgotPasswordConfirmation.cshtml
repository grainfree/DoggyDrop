@page
@{
    ViewData["Title"] = "Email poslan";
}

<section class="auth-shell">
    <div class="auth-shell__panel">
        <div class="auth-brand">
            <img src="~/images/logo_transparent.png" alt="DoggyDrop" asp-append-version="true" />
        </div>
        <div class="auth-hero">
            <span>Preveri inbox</span>
            <h1>Povezava je poslana.</h1>
            <p>Če email obstaja v DoggyDrop, bo v nekaj minutah prispela povezava za ponastavitev gesla.</p>
        </div>
        <p class="auth-switch">
            <a asp-page="./Login">Nazaj na prijavo</a>
        </p>
    </div>
</section>
