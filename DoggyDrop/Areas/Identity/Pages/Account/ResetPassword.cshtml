@page
@model ResetPasswordModel
@{
    ViewData["Title"] = "Novo geslo";
}

<section class="auth-shell">
    <div class="auth-shell__panel">
        <div class="auth-brand">
            <img src="~/images/logo_transparent.png" alt="DoggyDrop" asp-append-version="true" />
        </div>
        <div class="auth-hero">
            <span>Novo geslo</span>
            <h1>Nastavi novo geslo.</h1>
            <p>Vpiši email in novo geslo za svoj DoggyDrop račun.</p>
        </div>
        <form method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            <input asp-for="Input.Code" type="hidden" />
            <div class="auth-field">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" class="form-control" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>
            <div class="auth-field">
                <label asp-for="Input.Password">Novo geslo</label>
                <input asp-for="Input.Password" class="form-control" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>
            <div class="auth-field">
                <label asp-for="Input.ConfirmPassword">Potrdi geslo</label>
                <input asp-for="Input.ConfirmPassword" class="form-control" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-success auth-submit">Shrani novo geslo</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
