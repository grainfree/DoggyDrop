@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Pozabljeno geslo";
}

<section class="auth-shell">
    <div class="auth-shell__panel">
        <div class="auth-brand">
            <img src="~/images/logo_transparent.png" alt="DoggyDrop" asp-append-version="true" />
        </div>

        <div class="auth-hero">
            <span>Obnova dostopa</span>
            <h1>Ponastavi geslo.</h1>
            <p>Vpiši email in poslali ti bomo povezavo za novo geslo.</p>
        </div>

        <form method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
            <div class="auth-field">
                <label asp-for="Input.Email">Email</label>
                <input asp-for="Input.Email" class="form-control" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-success auth-submit">Pošlji povezavo</button>
        </form>

        <p class="auth-switch">
            <a asp-page="./Login">Nazaj na prijavo</a>
        </p>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

