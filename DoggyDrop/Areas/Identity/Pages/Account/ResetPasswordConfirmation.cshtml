@page
@{
    ViewData["Title"] = "Geslo posodobljeno";
}

<section class="auth-shell">
    <div class="auth-shell__panel">
        <div class="auth-brand">
            <img src="~/images/logo_transparent.png" alt="DoggyDrop" asp-append-version="true" />
        </div>
        <div class="auth-hero">
            <span>Urejeno</span>
            <h1>Geslo je posodobljeno.</h1>
            <p>Zdaj se lahko prijaviš z novim geslom.</p>
        </div>
        <p class="auth-switch">
            <a asp-page="./Login">Nazaj na prijavo</a>
        </p>
    </div>
</section>
