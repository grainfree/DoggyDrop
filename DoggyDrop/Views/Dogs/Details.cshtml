@model DoggyDrop.ViewModels.DogDetailsViewModel

@{
    ViewData["Title"] = Model.Dog.Name;
    var totalHours = Math.Floor(Model.TotalDuration.TotalHours);
    var totalMinutes = Model.TotalDuration.Minutes;
}

<section class="app-page dog-profile">
    <a class="dog-profile__back" asp-controller="Dogs" asp-action="Index">Nazaj na pse</a>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-warning">@TempData["ErrorMessage"]</div>
    }

    <header class="dog-profile__hero">
        <div class="dog-profile__photo">
            @if (!string.IsNullOrWhiteSpace(Model.Dog.PhotoUrl))
            {
                <img src="@Model.Dog.PhotoUrl" alt="@Model.Dog.Name" />
            }
            else
            {
                <span>@Model.Dog.Name.Substring(0, 1).ToUpperInvariant()</span>
            }
        </div>

        <div class="dog-profile__intro">
            <h1>@Model.Dog.Name</h1>
            <p>@(string.IsNullOrWhiteSpace(Model.Dog.Breed) ? "Pasma še ni dodana" : Model.Dog.Breed)</p>
            <div class="dog-profile__chips">
                @if (Model.Dog.NearbyVisibility == "Visible")
                {
                    <span>Viden v bližini</span>
                }
                else if (Model.Dog.NearbyVisibility == "FriendsOnly")
                {
                    <span>Samo prijatelji</span>
                }
                @if (Model.Dog.AgeYears.HasValue)
                {
                    <span>@Model.Dog.AgeYears let</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Dog.Gender))
                {
                    <span>@Model.Dog.Gender</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Dog.Size))
                {
                    <span>@Model.Dog.Size</span>
                }
            </div>
            <div class="dog-profile__hero-actions">
                <a class="btn btn-success rounded-pill fw-semibold" asp-controller="Walks" asp-action="Index">Sprehodi</a>
                <a class="btn btn-outline-secondary rounded-pill" asp-controller="Dogs" asp-action="Edit" asp-route-id="@Model.Dog.Id">Uredi</a>
            </div>
        </div>
    </header>

    <article class="dog-profile__section">
        <h2>Fotografija</h2>
        <form asp-controller="Dogs" asp-action="UpdatePhoto" asp-route-id="@Model.Dog.Id" method="post" enctype="multipart/form-data" class="dog-profile__photo-form">
            <input type="file" name="photo" accept="image/*" class="form-control" />
            <button type="submit" class="btn btn-success rounded-pill fw-semibold">Shrani fotografijo</button>
        </form>
    </article>

    @if (!string.IsNullOrWhiteSpace(Model.Dog.Character))
    {
        <article class="dog-profile__section">
            <h2>Karakter</h2>
            <p>@Model.Dog.Character</p>
        </article>
    }

    <div class="dog-profile__stats">
        <article>
            <strong>@Model.TotalDistanceKm.ToString("0.0") km</strong>
            <span>Skupaj</span>
        </article>
        <article>
            <strong>@Model.CompletedWalkCount</strong>
            <span>Sprehodi</span>
        </article>
        <article>
            <strong>@($"{totalHours:0}h {totalMinutes:00}m")</strong>
            <span>Aktivno</span>
        </article>
        <article>
            <strong>@Model.EstimatedCalories</strong>
            <span>kcal ocena</span>
        </article>
        <article>
            <strong>@Model.ParkVisitCount</strong>
            <span>Parki</span>
        </article>
    </div>

    <article class="dog-profile__section">
        <div class="dog-profile__section-header">
            <h2>Najljubši parki</h2>
            <span>@Model.FavoriteParks.Count lokacij</span>
        </div>

        @if (Model.FavoriteParks.Count == 0)
        {
            <p>Ko na zemljevidu zabeležiš obisk pasjega parka, se bodo tukaj pokazale najljubše lokacije tvojega psa.</p>
            <a class="btn btn-outline-secondary rounded-pill" asp-controller="Map" asp-action="Index">Odpri zemljevid</a>
        }
        else
        {
            <div class="dog-profile__park-list">
                @foreach (var park in Model.FavoriteParks)
                {
                    <div class="dog-profile__park-item">
                        <div>
                            <strong>@park.ParkName</strong>
                            <span>@(string.IsNullOrWhiteSpace(park.Area) ? "Pasji park" : park.Area) · nazadnje @park.LastVisitedAt.ToLocalTime().ToString("dd.MM.")</span>
                        </div>
                        <em>@park.VisitCount x</em>
                    </div>
                }
            </div>
        }
    </article>

    <article class="dog-profile__section">
        <div class="dog-profile__section-header">
            <h2>Aktivnost psa</h2>
            <span>@Model.ActivityInsights.CurrentStreakDays dni streak</span>
        </div>
        <div class="dog-profile__goal-grid">
            <div>
                <strong>Teden</strong>
                <span>@Model.ActivityInsights.WeeklyDistanceKm.ToString("0.0") / @Model.ActivityInsights.WeeklyGoalKm.ToString("0") km</span>
                <em><i style="width: @Model.ActivityInsights.WeeklyGoalPercent%"></i></em>
            </div>
            <div>
                <strong>Mesec</strong>
                <span>@Model.ActivityInsights.MonthlyDistanceKm.ToString("0.0") / @Model.ActivityInsights.MonthlyGoalKm.ToString("0") km</span>
                <em><i style="width: @Model.ActivityInsights.MonthlyGoalPercent%"></i></em>
            </div>
            <div>
                <strong>@Model.ActivityInsights.NextMilestoneName</strong>
                <span>@Model.ActivityInsights.NextMilestoneProgress</span>
                <em><i style="width: @Model.ActivityInsights.NextMilestonePercent%"></i></em>
            </div>
        </div>
    </article>

    <article class="dog-profile__section">
        <div class="dog-profile__section-header">
            <h2>Dosežki</h2>
            <span>@Model.Achievements.Count(achievement => achievement.IsUnlocked) / @Model.Achievements.Count odklenjenih</span>
        </div>
        <div class="dog-profile__achievements">
            @foreach (var achievement in Model.Achievements)
            {
                <div class="dog-profile__achievement @(achievement.IsUnlocked ? "is-unlocked" : "is-locked")">
                    <div>
                        <strong>@achievement.Name</strong>
                        <span>@(achievement.IsUnlocked ? "Odklenjeno" : achievement.ProgressText)</span>
                    </div>
                    <p>@achievement.Description</p>
                    <div class="dog-profile__achievement-bar">
                        <span style="width: @achievement.ProgressPercent%"></span>
                    </div>
                </div>
            }
        </div>
    </article>

    <article class="dog-profile__section">
        <div class="dog-profile__section-header">
            <h2>Zadnji sprehodi</h2>
            <span>@Model.WalksThisWeek ta teden</span>
        </div>

        @if (Model.RecentWalks.Count == 0)
        {
            <p>Ta pes še nima zaključenih sprehodov. Začni prvi sprehod in profil bo oživel s statistiko.</p>
        }
        else
        {
            <div class="dog-profile__walk-list">
                @foreach (var walk in Model.RecentWalks)
                {
                    var duration = walk.EndedAt.HasValue ? walk.EndedAt.Value - walk.StartedAt : TimeSpan.Zero;
                    <a class="dog-profile__walk-item" asp-controller="Walks" asp-action="Details" asp-route-id="@walk.Id">
                        <div>
                            <strong>@walk.StartedAt.ToLocalTime().ToString("dd.MM.yyyy")</strong>
                            <span>@walk.StartedAt.ToLocalTime().ToString("HH:mm") · @duration.ToString(@"hh\:mm")</span>
                        </div>
                        <span>@((walk.DistanceMeters / 1000).ToString("0.0")) km</span>
                    </a>
                }
            </div>
        }

        <form asp-controller="Walks" asp-action="Start" method="post" class="dog-profile__start-form">
            <input type="hidden" name="dogId" value="@Model.Dog.Id" />
            <button type="submit" class="btn btn-success rounded-pill fw-semibold">Začni sprehod</button>
            <a class="btn btn-outline-secondary rounded-pill" asp-controller="Walks" asp-action="Index">Vsi sprehodi</a>
        </form>
    </article>
</section>

<style>
    .dog-profile__back {
        display: inline-flex;
        margin-bottom: 14px;
        color: #2f6d5f;
        font-weight: 800;
        text-decoration: none;
    }

    .dog-profile__hero,
    .dog-profile__section,
    .dog-profile__stats article {
        border: 1px solid rgba(31, 45, 41, 0.08);
        border-radius: 22px;
        background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(249,252,247,0.96));
        box-shadow: 0 18px 34px rgba(31, 45, 41, 0.08);
    }

    .dog-profile__hero {
        display: grid;
        grid-template-columns: minmax(220px, 320px) 1fr;
        gap: 20px;
        align-items: center;
        padding: 20px;
    }

    .dog-profile__photo {
        display: grid;
        width: 100%;
        aspect-ratio: 4 / 3;
        place-items: center;
        overflow: hidden;
        border-radius: 20px;
        background: linear-gradient(135deg, #e7f3e5, #fff3dd);
        color: #2f6d5f;
        font-size: 4rem;
        font-weight: 900;
    }

    .dog-profile__photo img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
    }

    .dog-profile__intro h1 {
        margin: 0;
        font-size: clamp(2rem, 8vw, 3.3rem);
        font-weight: 900;
        line-height: 1;
    }

    .dog-profile__intro p {
        margin: 8px 0 0;
        color: #65716d;
        font-size: 1.05rem;
    }

    .dog-profile__chips,
    .dog-profile__hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 14px;
    }

    .dog-profile__chips span {
        padding: 7px 11px;
        border-radius: 999px;
        background: rgba(47, 109, 95, 0.10);
        color: #2f6d5f;
        font-size: 0.82rem;
        font-weight: 850;
    }

    .dog-profile__hero-actions .btn {
        min-width: 120px;
    }

    .dog-profile__section {
        margin-top: 14px;
        padding: 20px;
    }

    .dog-profile__section h2 {
        margin: 0 0 8px;
        font-size: 1rem;
        font-weight: 900;
    }

    .dog-profile__section-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 8px;
    }

    .dog-profile__section-header h2 {
        margin: 0;
    }

    .dog-profile__section-header span {
        color: #2f6d5f;
        font-size: 0.82rem;
        font-weight: 850;
    }

    .dog-profile__section p {
        margin: 0;
        color: #65716d;
    }

    .dog-profile__achievements {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
        margin-top: 12px;
    }

    .dog-profile__achievement {
        padding: 12px;
        border: 1px solid rgba(31, 45, 41, 0.08);
        border-radius: 16px;
        background: #f8faf7;
    }

    .dog-profile__achievement.is-unlocked {
        background: #eef7ed;
    }

    .dog-profile__achievement div:first-child {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 8px;
    }

    .dog-profile__achievement strong {
        color: #1f2d29;
        font-weight: 950;
    }

    .dog-profile__achievement div:first-child span {
        color: #2f6d5f;
        font-size: 0.76rem;
        font-weight: 900;
        text-align: right;
        white-space: nowrap;
    }

    .dog-profile__achievement p {
        margin: 6px 0 10px;
        font-size: 0.84rem;
        font-weight: 700;
        line-height: 1.3;
    }

    .dog-profile__achievement-bar {
        overflow: hidden;
        height: 8px;
        border-radius: 999px;
        background: rgba(47, 109, 95, 0.12);
    }

    .dog-profile__achievement-bar span {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: #2f6d5f;
    }

    .dog-profile__section .btn {
        margin-top: 14px;
    }

    .dog-profile__goal-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
        margin-top: 12px;
    }

    .dog-profile__goal-grid div {
        padding: 12px;
        border: 1px solid rgba(31, 45, 41, 0.08);
        border-radius: 16px;
        background: #f8faf7;
    }

    .dog-profile__goal-grid strong,
    .dog-profile__goal-grid span {
        display: block;
    }

    .dog-profile__goal-grid strong {
        color: #1f2d29;
        font-weight: 950;
    }

    .dog-profile__goal-grid span {
        color: #2f6d5f;
        font-size: 0.8rem;
        font-weight: 900;
    }

    .dog-profile__goal-grid em {
        display: block;
        overflow: hidden;
        height: 8px;
        margin-top: 10px;
        border-radius: 999px;
        background: rgba(47, 109, 95, 0.12);
    }

    .dog-profile__goal-grid i {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: #2f6d5f;
    }

    .dog-profile__photo-form {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 10px;
        align-items: center;
    }

    .dog-profile__photo-form .btn {
        margin-top: 0;
        white-space: nowrap;
    }

    .dog-profile__walk-list {
        display: grid;
        gap: 10px;
        margin-top: 12px;
    }

    .dog-profile__walk-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 0;
        border-top: 1px solid rgba(31, 45, 41, 0.08);
        color: inherit;
        text-decoration: none;
    }

    .dog-profile__walk-item:first-child {
        border-top: 0;
    }

    .dog-profile__walk-item:hover,
    .dog-profile__walk-item:focus {
        color: #2f6d5f;
    }

    .dog-profile__walk-item strong,
    .dog-profile__walk-item span {
        display: block;
    }

    .dog-profile__walk-item div span {
        color: #65716d;
        font-size: 0.88rem;
    }

    .dog-profile__start-form {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 14px;
    }

    .dog-profile__stats {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 12px;
        margin-top: 14px;
    }

    .dog-profile__park-list {
        display: grid;
        gap: 10px;
        margin-top: 12px;
    }

    .dog-profile__park-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 12px;
        border: 1px solid rgba(31, 45, 41, 0.08);
        border-radius: 16px;
        background: #f8faf7;
    }

    .dog-profile__park-item strong,
    .dog-profile__park-item span {
        display: block;
    }

    .dog-profile__park-item strong {
        color: #1f2d29;
        font-weight: 950;
    }

    .dog-profile__park-item span {
        color: #65716d;
        font-size: 0.84rem;
    }

    .dog-profile__park-item em {
        color: #2f6d5f;
        font-style: normal;
        font-weight: 950;
        white-space: nowrap;
    }

    .dog-profile__stats article {
        padding: 18px;
        background: linear-gradient(180deg, #ffffff, #f7faf6);
    }

    .dog-profile__stats strong,
    .dog-profile__stats span {
        display: block;
    }

    .dog-profile__stats strong {
        color: #21342f;
        font-size: 1.45rem;
        font-weight: 900;
    }

    .dog-profile__stats span {
        color: #65716d;
        font-weight: 750;
    }

    @@media (max-width: 575.98px) {
        .dog-profile__hero {
            grid-template-columns: 1fr;
        }

        .dog-profile__photo {
            width: 100%;
        }

        .dog-profile__stats {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .dog-profile__achievements,
        .dog-profile__goal-grid {
            grid-template-columns: 1fr;
        }

        .dog-profile__section-header,
        .dog-profile__walk-item,
        .dog-profile__hero-actions,
        .dog-profile__start-form,
        .dog-profile__photo-form {
            align-items: stretch;
            flex-direction: column;
        }

        .dog-profile__start-form .btn {
            width: 100%;
        }

        .dog-profile__photo-form {
            display: flex;
        }

        .dog-profile__photo-form .btn {
            width: 100%;
        }
    }
</style>
