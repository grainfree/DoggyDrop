@model DoggyDrop.ViewModels.DogCreateViewModel

@{
    ViewData["Title"] = "Dodaj psa";
    var dogIconOptions = new[]
    {
        ("dog-face", "Klasik"),
        ("beagle", "Beagle"),
        ("retriever", "Retriever"),
        ("terrier", "Terier"),
        ("poodle", "Pudelj"),
        ("husky", "Husky"),
        ("bulldog", "Bulldog"),
        ("dachshund", "Jazbečar"),
        ("shepherd", "Ovčar"),
        ("spaniel", "Španjel"),
        ("shiba", "Shiba"),
        ("dalmatian", "Dalmatinec"),
        ("puppy", "Mladič"),
        ("senior", "Senior"),
        ("small-dog", "Mali pes"),
        ("big-dog", "Velik pes")
    };
}

<section class="app-page dog-form-page">
    <header class="app-page__header">
        <span class="dog-form-page__eyebrow">DoggyDrop profil</span>
        <h1 class="app-page__title">Dodaj svojega kužka</h1>
        <p class="app-page__lead">
            @if (Model.IsFirstDog)
            {
                <text>Najprej dodaj svojega pasjega sopotnika, da bo DoggyDrop lahko meril sprehode, zbiral značke in pripravljal boljše predloge poti.</text>
            }
            else
            {
                <text>Vsak kuža dobi svoj profil, svojo statistiko in svoje sprehode. Dodaj še enega člana pasje ekipe.</text>
            }
        </p>
    </header>

    @if (Model.IsFirstDog)
    {
        <section class="dog-onboarding-card">
            <div class="dog-onboarding-card__icon">🐾</div>
            <div>
                <h2>Začni z osnovami, ostalo pa pride sproti</h2>
                <p>Dovolj je ime in ena simpatična fotka. Če dodaš še pasmo, velikost in karakter, bo app znal pripraviti bolj osebne sprehode.</p>
            </div>
            <div class="dog-onboarding-card__chips" aria-label="Kaj je dobro dodati">
                <span>Ime</span>
                <span>Fotografija</span>
                <span>Pasma</span>
                <span>Velikost</span>
                <span>Karakter</span>
            </div>
        </section>
    }

    <form asp-action="Create" method="post" enctype="multipart/form-data" class="dog-form">
        <input asp-for="ReturnUrl" type="hidden" />
        <input asp-for="IsFirstDog" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label">Ime psa</label>
            <input asp-for="Name" class="form-control" placeholder="Npr. Luna" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Breed" class="form-label">Pasma</label>
            <input asp-for="Breed" class="form-control" placeholder="Npr. Jack Russell terier" />
            <span asp-validation-for="Breed" class="text-danger small"></span>
        </div>

        <div class="dog-form__grid">
            <div class="mb-3">
                <label asp-for="AgeYears" class="form-label">Starost</label>
                <input asp-for="AgeYears" type="number" min="0" max="30" class="form-control" placeholder="3" />
                <span asp-validation-for="AgeYears" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Gender" class="form-label">Spol</label>
                <select asp-for="Gender" class="form-select">
                    <option value="">Izberi</option>
                    <option>Samcek</option>
                    <option>Samicka</option>
                </select>
                <span asp-validation-for="Gender" class="text-danger small"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Size" class="form-label">Velikost</label>
            <select asp-for="Size" class="form-select">
                <option value="">Izberi velikost</option>
                <option>Majhen</option>
                <option>Srednji</option>
                <option>Velik</option>
            </select>
            <span asp-validation-for="Size" class="text-danger small"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Character" class="form-label">Karakter</label>
            <textarea asp-for="Character" class="form-control" rows="3" placeholder="Npr. igriv, radoveden, miren v parku"></textarea>
            <span asp-validation-for="Character" class="text-danger small"></span>
        </div>

        <section class="dog-icon-picker">
            <div class="dog-icon-picker__header">
                <label class="form-label">Ikona na zemljevidu</label>
                <span>Izberi marker, po katerem ga boš takoj prepoznal.</span>
            </div>
            <div class="dog-icon-picker__grid">
                @foreach (var option in dogIconOptions)
                {
                    var isSelected = string.Equals(Model.MapIconKey, option.Item1, StringComparison.OrdinalIgnoreCase);
                    <label class="dog-icon-option @(isSelected ? "is-active" : "")">
                        <input asp-for="MapIconKey" type="radio" value="@option.Item1" checked="@isSelected" />
                        <span class="dog-map-icon dog-map-icon--@option.Item1" aria-hidden="true">
                            <span></span>
                        </span>
                        <strong>@option.Item2</strong>
                    </label>
                }
            </div>
            <span asp-validation-for="MapIconKey" class="text-danger small"></span>
        </section>

        <div class="mb-4">
            <label asp-for="Photo" class="form-label">Fotografija</label>
            <input asp-for="Photo" type="file" accept="image/*" class="form-control" />
            <div class="form-text">Telefon fotko doda takoj, profil pa bo videti precej bolj živ.</div>
            <span asp-validation-for="Photo" class="text-danger small"></span>
        </div>

        <div class="dog-form__actions">
            @if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
            {
                <a class="btn btn-outline-secondary rounded-pill" href="@Model.ReturnUrl">Nazaj</a>
            }
            else
            {
                <a class="btn btn-outline-secondary rounded-pill" asp-controller="Dogs" asp-action="Index">Nazaj</a>
            }
            <button type="submit" class="btn btn-success rounded-pill fw-semibold">Shrani profil psa</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .dog-form-page__eyebrow {
        display: inline-block;
        margin-bottom: 10px;
        color: #ef8f42;
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0.06em;
        text-transform: uppercase;
    }

    .dog-onboarding-card {
        display: grid;
        gap: 12px;
        align-items: start;
        max-width: 640px;
        margin-bottom: 16px;
        padding: 16px 18px;
        border: 1px solid rgba(47, 109, 95, 0.14);
        border-radius: 18px;
        background:
            radial-gradient(circle at top right, rgba(239, 143, 66, 0.14), transparent 34%),
            linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(245, 250, 247, 0.98));
        box-shadow: 0 16px 38px rgba(31, 45, 41, 0.08);
    }

    .dog-onboarding-card__icon {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        background: rgba(47, 109, 95, 0.10);
        display: grid;
        place-items: center;
        font-size: 1.4rem;
    }

    .dog-onboarding-card h2 {
        margin: 0 0 6px;
        font-size: 1.05rem;
        font-weight: 900;
        color: #1f2d29;
    }

    .dog-onboarding-card p {
        margin: 0;
        color: #5f6f68;
        line-height: 1.55;
    }

    .dog-onboarding-card__chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .dog-onboarding-card__chips span {
        display: inline-flex;
        align-items: center;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(47, 109, 95, 0.10);
        color: #2f6d5f;
        font-size: 0.78rem;
        font-weight: 800;
    }

    .dog-form {
        max-width: 640px;
        padding: 18px;
        border: 1px solid rgba(31, 45, 41, 0.1);
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 12px 28px rgba(31, 45, 41, 0.08);
    }

    .dog-form__grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .dog-icon-picker {
        display: grid;
        gap: 10px;
        margin: 4px 0 18px;
    }

    .dog-icon-picker__header {
        display: grid;
        gap: 2px;
    }

    .dog-icon-picker__header .form-label {
        margin: 0;
    }

    .dog-icon-picker__header span {
        color: #65716d;
        font-size: 0.86rem;
        font-weight: 700;
    }

    .dog-icon-picker__grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 8px;
    }

    .dog-icon-option {
        display: grid;
        gap: 7px;
        place-items: center;
        min-height: 92px;
        padding: 10px 8px;
        border: 1px solid rgba(31, 45, 41, 0.1);
        border-radius: 8px;
        background: #f8faf7;
        color: #21342f;
        cursor: pointer;
    }

    .dog-icon-option input {
        position: absolute;
        opacity: 0;
        pointer-events: none;
    }

    .dog-icon-option strong {
        font-size: 0.76rem;
        font-weight: 900;
        text-align: center;
    }

    .dog-icon-option.is-active {
        border-color: #2f6d5f;
        background: #e7f3ed;
        box-shadow: inset 0 0 0 2px rgba(47, 109, 95, 0.12);
    }

    .dog-map-icon {
        position: relative;
        display: inline-grid;
        width: 44px;
        height: 44px;
        place-items: center;
        border: 3px solid #ffffff;
        border-radius: 999px;
        background: #f3c879;
        box-shadow: 0 8px 18px rgba(31, 45, 41, 0.18);
    }

    .dog-map-icon::before,
    .dog-map-icon::after {
        position: absolute;
        top: 7px;
        width: 13px;
        height: 19px;
        border-radius: 12px 12px 12px 4px;
        background: #8d5b32;
        content: "";
    }

    .dog-map-icon::before {
        left: -4px;
        transform: rotate(-26deg);
    }

    .dog-map-icon::after {
        right: -4px;
        transform: rotate(26deg);
    }

    .dog-map-icon span {
        position: relative;
        width: 18px;
        height: 13px;
        border-radius: 0 0 14px 14px;
        background: rgba(255, 255, 255, 0.72);
    }

    .dog-map-icon span::before,
    .dog-map-icon span::after {
        position: absolute;
        top: -8px;
        width: 4px;
        height: 4px;
        border-radius: 999px;
        background: #21342f;
        content: "";
    }

    .dog-map-icon span::before { left: 2px; }
    .dog-map-icon span::after { right: 2px; }

    .dog-map-icon--beagle { background: #d99a53; }
    .dog-map-icon--retriever { background: #e6bd62; }
    .dog-map-icon--terrier { background: #f3f0df; }
    .dog-map-icon--poodle { background: #f5e9ef; }
    .dog-map-icon--husky { background: #dce8ef; }
    .dog-map-icon--bulldog { background: #c88b62; }
    .dog-map-icon--dachshund { background: #9a6032; }
    .dog-map-icon--shepherd { background: #b37b42; }
    .dog-map-icon--spaniel { background: #d48357; }
    .dog-map-icon--shiba { background: #e08a3e; }
    .dog-map-icon--dalmatian { background: #f7f7f2; }
    .dog-map-icon--puppy { background: #f2d58a; }
    .dog-map-icon--senior { background: #d9d2c4; }
    .dog-map-icon--small-dog { width: 38px; height: 38px; }
    .dog-map-icon--big-dog { width: 50px; height: 50px; }

    .dog-map-icon--poodle::before,
    .dog-map-icon--poodle::after,
    .dog-map-icon--husky::before,
    .dog-map-icon--husky::after,
    .dog-map-icon--dalmatian::before,
    .dog-map-icon--dalmatian::after,
    .dog-map-icon--terrier::before,
    .dog-map-icon--terrier::after {
        background: #6d6258;
    }

    .dog-form__actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .dog-form__actions .btn {
        min-width: 130px;
    }

    @@media (max-width: 575.98px) {
        .dog-onboarding-card {
            padding: 14px;
            border-radius: 16px;
        }

        .dog-form__grid {
            grid-template-columns: 1fr;
            gap: 0;
        }

        .dog-icon-picker__grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .dog-form__actions {
            flex-direction: column-reverse;
        }

        .dog-form__actions .btn {
            width: 100%;
        }
    }
</style>
