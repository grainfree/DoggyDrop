@using DoggyDrop.ViewModels
@model UserProfileViewModel

@{
    ViewData["Title"] = "Profil";
    var displayName = string.IsNullOrWhiteSpace(Model.DisplayName) ? Model.Email : Model.DisplayName;
    var initials = string.IsNullOrWhiteSpace(displayName) ? "D" : displayName.Substring(0, 1).ToUpperInvariant();
    var totalHours = Math.Floor(Model.TotalWalkDuration.TotalHours);
    var totalMinutes = Model.TotalWalkDuration.Minutes;
}

<section class="app-page profile-page">
    <header class="profile-hero">
        <div class="profile-hero__avatar profile-hero__avatar--@Model.Gamification.AvatarFlameTier">
            @if (!string.IsNullOrWhiteSpace(Model.ProfileImageUrl))
            {
                <img src="@Model.ProfileImageUrl" alt="@displayName" />
            }
            else
            {
                <span>@initials</span>
            }
        </div>
        <div class="profile-hero__text">
            <span>DoggyDrop profil</span>
            <h1>@displayName</h1>
            <p>@Model.Email</p>
            <div class="profile-hero__actions" aria-label="Profil akcije">
                <a asp-controller="Home" asp-action="Settings">Nastavitve</a>
                <form asp-area="Identity"
                      asp-page="/Account/Logout"
                      asp-route-returnUrl="/Identity/Account/Login"
                      method="post">
                    <button type="submit">Odjava</button>
                </form>
            </div>
        </div>
    </header>

    <article class="profile-panel profile-xp">
        <div class="profile-xp__top">
            <div>
                <span>Level @Model.Gamification.Level</span>
                <strong>@Model.Gamification.Title</strong>
            </div>
            <em>@Model.Gamification.TotalXp XP</em>
        </div>
        <div class="profile-achievement__bar">
            <span style="width: @Model.Gamification.ProgressPercent%"></span>
        </div>
        <div class="profile-xp__meta">
            <span>@Model.Gamification.XpRemaining XP do naslednjega levela</span>
            <span>@Model.Gamification.CurrentStreakDays dni daily streak</span>
        </div>
        <div class="profile-streak-grid">
            @foreach (var streak in Model.Gamification.Streaks)
            {
                <div class="profile-streak profile-streak--@streak.FlameTier">
                    <span class="profile-streak__flame" aria-hidden="true"></span>
                    <div>
                        <strong>@streak.CurrentDays dni</strong>
                        <span>@streak.Label</span>
                    </div>
                    <em>@streak.LongestDays best</em>
                </div>
            }
        </div>
    </article>

    <article class="profile-panel profile-seasonal profile-seasonal--@Model.SeasonalMapTheme">
        <div class="profile-panel__header">
            <h2>Seasonal events</h2>
            <span>@Model.SeasonalMapTheme theme</span>
        </div>

        @if (Model.SeasonalEvents.Count == 0)
        {
            <p class="profile-muted">Naslednji sezonski event se pripravlja. Limited badge in map skin se odkleneta tukaj.</p>
        }
        else
        {
            <div class="profile-seasonal-list">
                @foreach (var seasonalEvent in Model.SeasonalEvents)
                {
                    <div class="profile-seasonal-card profile-seasonal-card--@seasonalEvent.Theme @(seasonalEvent.IsComplete ? "is-complete" : "")">
                        <div class="profile-seasonal-card__top">
                            <div>
                                <strong>@seasonalEvent.Name</strong>
                                <span>@seasonalEvent.Description</span>
                            </div>
                            <em>@seasonalEvent.Current / @seasonalEvent.Target</em>
                        </div>
                        <div class="profile-achievement__bar">
                            <span style="width: @seasonalEvent.ProgressPercent%"></span>
                        </div>
                        <p>@(seasonalEvent.IsComplete ? "Reward unlocked" : "Limited reward") · @seasonalEvent.RewardName · do @seasonalEvent.EndsOn.ToString("dd.MM.")</p>
                    </div>
                }
            </div>
        }
    </article>

    <article class="profile-panel profile-founders">
        <div class="profile-panel__header">
            <h2>Founder badges</h2>
            <span>@Model.FounderBadges.Count permanent</span>
        </div>

        @if (Model.FounderBadges.Count == 0)
        {
            <div class="profile-founder-empty">
                <strong>Be the first DoggyDrop Explorer here.</strong>
                <p>Dodaj prvi odobren pasji koš v kraju, kjer DoggyDrop še nima pokritosti, in dobiš trajen founder badge na profilu.</p>
                <a asp-controller="Map" asp-action="Add">Dodaj koš</a>
            </div>
        }
        else
        {
            <div class="profile-founder-list">
                @foreach (var badge in Model.FounderBadges)
                {
                    <div class="profile-founder-badge">
                        <span>Founder</span>
                        <strong>@badge.AreaName</strong>
                        <em>@badge.UnlockedAt.ToLocalTime().ToString("dd.MM.yyyy")</em>
                    </div>
                }
            </div>
        }
    </article>

    <article class="profile-panel profile-stamps">
        <div class="profile-panel__header">
            <h2>Map stamps</h2>
            <span>@Model.MapStamps.TotalStamps collected</span>
        </div>

        <div class="profile-stamp-summary">
            <span><strong>@Model.MapStamps.CommonCount</strong> Common</span>
            <span><strong>@Model.MapStamps.RareCount</strong> Rare</span>
            <span><strong>@Model.MapStamps.EpicCount</strong> Epic</span>
            <span><strong>@Model.MapStamps.LegendaryCount</strong> Legendary</span>
        </div>

        @if (Model.MapStamps.Stamps.Count == 0)
        {
            <p class="profile-muted">Zabelezi prvi obisk parka in DoggyDrop bo odklenil prvi stamp v tvojem albumu.</p>
        }
        else
        {
            <div class="profile-stamp-book">
                @foreach (var stamp in Model.MapStamps.Stamps)
                {
                    <div class="profile-stamp profile-stamp--@stamp.Rarity.ToLowerInvariant()">
                        <div class="profile-stamp__mark">@stamp.Name.Substring(0, 1).ToUpperInvariant()</div>
                        <div>
                            <strong>@stamp.Name</strong>
                            <span>@(string.IsNullOrWhiteSpace(stamp.Area) ? "DoggyDrop location" : stamp.Area)</span>
                            <em>@stamp.Rarity · @stamp.VisitCount x · @stamp.LastCollectedAt.ToLocalTime().ToString("dd.MM.")</em>
                        </div>
                    </div>
                }
            </div>
        }
    </article>

    <div class="profile-stats">
        <article>
            <strong>@Model.TotalDistanceKm.ToString("0.0") km</strong>
            <span>Skupaj</span>
        </article>
        <article>
            <strong>@Model.TotalWalks</strong>
            <span>Sprehodi</span>
        </article>
        <article>
            <strong>@Model.WalksThisWeek</strong>
            <span>Ta teden</span>
        </article>
        <article>
            <strong>@Model.TotalDogs</strong>
            <span>Psi</span>
        </article>
        <article>
            <strong>@Model.TotalBins</strong>
            <span>Kosi</span>
        </article>
        <article>
            <strong>@($"{totalHours:0}h {totalMinutes:00}m")</strong>
            <span>Aktivno</span>
        </article>
    </div>

    <article class="profile-panel profile-activity">
        <div class="profile-panel__header">
            <h2>Aktivnost</h2>
            <span>@Model.ActivityInsights.CurrentStreakDays dni streak</span>
        </div>

        <div class="profile-goal-grid">
            <div class="profile-goal-card">
                <div>
                    <strong>Tedenski cilj</strong>
                    <span>@Model.ActivityInsights.WeeklyDistanceKm.ToString("0.0") / @Model.ActivityInsights.WeeklyGoalKm.ToString("0") km</span>
                </div>
                <div class="profile-achievement__bar">
                    <span style="width: @Model.ActivityInsights.WeeklyGoalPercent%"></span>
                </div>
            </div>
            <div class="profile-goal-card">
                <div>
                    <strong>Mesec</strong>
                    <span>@Model.ActivityInsights.MonthlyDistanceKm.ToString("0.0") / @Model.ActivityInsights.MonthlyGoalKm.ToString("0") km</span>
                </div>
                <div class="profile-achievement__bar">
                    <span style="width: @Model.ActivityInsights.MonthlyGoalPercent%"></span>
                </div>
            </div>
            <div class="profile-goal-card">
                <div>
                    <strong>@Model.ActivityInsights.NextMilestoneName</strong>
                    <span>@Model.ActivityInsights.NextMilestoneProgress</span>
                </div>
                <div class="profile-achievement__bar">
                    <span style="width: @Model.ActivityInsights.NextMilestonePercent%"></span>
                </div>
            </div>
        </div>

        <div class="profile-challenge-list">
            @foreach (var challenge in Model.ActivityInsights.Challenges)
            {
                <div class="profile-challenge @(challenge.IsComplete ? "is-complete" : "")">
                    <div>
                        <strong>@challenge.Title</strong>
                        <span>@challenge.ProgressText</span>
                    </div>
                    <p>@challenge.Description</p>
                    <div class="profile-achievement__bar">
                        <span style="width: @challenge.ProgressPercent%"></span>
                    </div>
                </div>
            }
        </div>
    </article>

    <article class="profile-panel">
        <div class="profile-panel__header">
            <h2>Dosezki</h2>
            <span>@Model.Achievements.Count(achievement => achievement.IsUnlocked) / @Model.Achievements.Count odklenjenih</span>
        </div>

        @if (Model.Achievements.Count == 0)
        {
            <p class="profile-muted">Dodaj psa, zacni sprehod ali dodaj kos in prve znacke se bodo odklenile.</p>
        }
        else
        {
            <div class="profile-achievements">
                @foreach (var achievement in Model.Achievements)
                {
                    <div class="profile-achievement @(achievement.IsUnlocked ? "is-unlocked" : "is-locked")">
                        <div class="profile-achievement__top">
                            <strong>@achievement.Name</strong>
                            <span>@(achievement.IsUnlocked ? "Odklenjeno" : achievement.ProgressText)</span>
                        </div>
                        <p>@achievement.Description</p>
                        <div class="profile-achievement__bar">
                            <span style="width: @achievement.ProgressPercent%"></span>
                        </div>
                    </div>
                }
            </div>
        }
    </article>

    <article class="profile-panel">
        <div class="profile-panel__header">
            <h2>Moji kosi</h2>
            <a asp-controller="Map" asp-action="MyBins">Odpri</a>
        </div>

        <div class="profile-bin-summary">
            <div>
                <strong>@Model.TotalBins</strong>
                <span>dodanih kosev</span>
            </div>
            <p>Preglej status odobritve, uporabo in prispevek proti znacki Bin Hero.</p>
        </div>
    </article>

    <article class="profile-panel">
        <div class="profile-panel__header">
            <h2>Moji psi</h2>
            <a asp-controller="Dogs" asp-action="Create">Dodaj</a>
        </div>

        @if (Model.Dogs.Count == 0)
        {
            <p class="profile-muted">Ni se dodanih psov. Profil psa je osnova za sprehode, kilometre in znacke.</p>
        }
        else
        {
            <div class="profile-dog-list">
                @foreach (var dog in Model.Dogs)
                {
                    <a class="profile-dog" asp-controller="Dogs" asp-action="Details" asp-route-id="@dog.Id">
                        <div class="profile-dog__avatar">
                            @if (!string.IsNullOrWhiteSpace(dog.PhotoUrl))
                            {
                                <img src="@dog.PhotoUrl" alt="@dog.Name" />
                            }
                            else
                            {
                                <span>@dog.Name.Substring(0, 1).ToUpperInvariant()</span>
                            }
                        </div>
                        <div>
                            <strong>@dog.Name</strong>
                            <span>@dog.WalkCount sprehodov</span>
                        </div>
                        <em>@dog.DistanceKm.ToString("0.0") km</em>
                    </a>
                }
            </div>
        }
    </article>

    <article class="profile-panel">
        <div class="profile-panel__header">
            <h2>Uredi profil</h2>
            <a asp-controller="Home" asp-action="Settings">Nastavitve</a>
        </div>

        <form asp-action="UpdateProfile" method="post" enctype="multipart/form-data" class="profile-form">
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

            <div>
                <label class="form-label">Vzdevek / ime</label>
                <input name="DisplayName" class="form-control" value="@Model.DisplayName" />
            </div>

            <div>
                <label class="form-label">Nova profilna slika</label>
                <input type="file" name="ProfileImage" class="form-control" />
            </div>

            <button type="submit" class="btn btn-success rounded-pill fw-semibold">Shrani spremembe</button>
        </form>
    </article>
</section>

<style>
    .profile-hero,
    .profile-stats article,
    .profile-panel {
        border: 1px solid rgba(31, 45, 41, 0.1);
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 12px 28px rgba(31, 45, 41, 0.08);
    }

    .profile-hero {
        display: grid;
        grid-template-columns: 96px 1fr;
        gap: 16px;
        align-items: center;
        padding: 18px;
    }

    .profile-hero__avatar,
    .profile-dog__avatar {
        display: grid;
        place-items: center;
        overflow: hidden;
        background: linear-gradient(135deg, #e7f3e5, #fff3dd);
        color: #2f6d5f;
        font-weight: 950;
    }

    .profile-hero__avatar {
        width: 96px;
        aspect-ratio: 1;
        border-radius: 8px;
        font-size: 2.4rem;
        position: relative;
        isolation: isolate;
    }

    .profile-hero__avatar::before {
        content: "";
        position: absolute;
        inset: -8px;
        z-index: -1;
        border-radius: 12px;
        opacity: 0;
        background: linear-gradient(135deg, #ffca5c, #ef6f3b);
    }

    .profile-hero__avatar--small::before {
        opacity: 0.62;
    }

    .profile-hero__avatar--glowing::before {
        opacity: 0.78;
        box-shadow: 0 0 28px rgba(239, 111, 59, 0.45);
    }

    .profile-hero__avatar--legendary::before {
        opacity: 0.92;
        background: linear-gradient(135deg, #fff48a, #ff9d3f 48%, #dd342d);
        box-shadow: 0 0 34px rgba(239, 111, 59, 0.56);
    }

    .profile-hero__avatar img,
    .profile-dog__avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .profile-hero__text span {
        color: #2f6d5f;
        font-size: 0.78rem;
        font-weight: 900;
        text-transform: uppercase;
    }

    .profile-hero__text h1 {
        margin: 4px 0;
        font-size: clamp(1.8rem, 7vw, 2.8rem);
        font-weight: 950;
        line-height: 1;
    }

    .profile-hero__text p,
    .profile-muted {
        margin: 0;
        color: #65716d;
    }

    .profile-hero__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 14px;
    }

    .profile-hero__actions a,
    .profile-hero__actions button {
        display: inline-flex;
        min-height: 42px;
        align-items: center;
        justify-content: center;
        padding: 9px 16px;
        border: 1px solid rgba(47, 109, 95, 0.18);
        border-radius: 999px;
        background: #eef7ed;
        color: #2f6d5f;
        font-weight: 900;
        text-decoration: none;
    }

    .profile-hero__actions form {
        margin: 0;
    }

    .profile-hero__actions button {
        background: #ffffff;
        color: #9b3b2f;
        border-color: rgba(155, 59, 47, 0.18);
    }

    .profile-xp {
        margin-top: 14px;
        background: linear-gradient(135deg, #ffffff 0%, #f3faf5 58%, #fff4e6 100%);
    }

    .profile-xp__top,
    .profile-xp__meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
    }

    .profile-xp__top span,
    .profile-xp__meta {
        color: #65716d;
        font-size: 0.84rem;
        font-weight: 850;
    }

    .profile-xp__top strong {
        display: block;
        color: #17322c;
        font-size: 1.45rem;
        font-weight: 950;
        line-height: 1.1;
    }

    .profile-xp__top em {
        color: #2f6d5f;
        font-style: normal;
        font-weight: 950;
    }

    .profile-xp__meta {
        margin-top: 8px;
        flex-wrap: wrap;
    }

    .profile-streak-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
        margin-top: 14px;
    }

    .profile-streak {
        display: grid;
        grid-template-columns: 30px 1fr auto;
        gap: 8px;
        align-items: center;
        min-width: 0;
        padding: 10px;
        border: 1px solid rgba(47, 109, 95, 0.12);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.72);
    }

    .profile-streak__flame {
        width: 22px;
        height: 28px;
        border-radius: 65% 65% 65% 10%;
        background: #d7ddd9;
        transform: rotate(45deg);
    }

    .profile-streak--small .profile-streak__flame {
        background: linear-gradient(135deg, #ffbf4c, #ef6f3b);
    }

    .profile-streak--glowing {
        box-shadow: 0 0 0 1px rgba(239, 143, 66, 0.20), 0 10px 24px rgba(239, 143, 66, 0.18);
    }

    .profile-streak--glowing .profile-streak__flame {
        background: linear-gradient(135deg, #ffe26b, #ff8b36 55%, #e24631);
    }

    .profile-streak--legendary {
        border-color: rgba(239, 143, 66, 0.42);
        background: linear-gradient(135deg, rgba(255, 250, 230, 0.96), rgba(255, 239, 212, 0.92));
        box-shadow: 0 0 0 1px rgba(239, 143, 66, 0.22), 0 14px 30px rgba(239, 143, 66, 0.22);
    }

    .profile-streak--legendary .profile-streak__flame {
        background: linear-gradient(135deg, #fff48a, #ff9d3f 46%, #dd342d);
    }

    .profile-streak strong,
    .profile-streak span,
    .profile-streak em {
        display: block;
        min-width: 0;
    }

    .profile-streak strong {
        font-weight: 950;
    }

    .profile-streak span,
    .profile-streak em {
        color: #65716d;
        font-size: 0.78rem;
        font-style: normal;
        font-weight: 800;
    }

    .profile-seasonal {
        overflow: hidden;
        background:
            linear-gradient(135deg, rgba(255,255,255,0.98), rgba(238,247,237,0.94)),
            #ffffff;
    }

    .profile-seasonal--christmas {
        background:
            radial-gradient(circle at 18% 18%, rgba(255,255,255,0.88), transparent 12%),
            radial-gradient(circle at 78% 30%, rgba(255,255,255,0.72), transparent 10%),
            linear-gradient(135deg, #ffffff, #eaf5f2 52%, #f8e9e6);
    }

    .profile-seasonal--halloween {
        background: linear-gradient(135deg, #ffffff, #fff0df 52%, #f3e9ff);
    }

    .profile-seasonal-list {
        display: grid;
        gap: 10px;
    }

    .profile-seasonal-card {
        padding: 12px;
        border: 1px solid rgba(47, 109, 95, 0.12);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.78);
    }

    .profile-seasonal-card--spring {
        border-color: rgba(67, 142, 90, 0.20);
    }

    .profile-seasonal-card--summer {
        border-color: rgba(239, 143, 66, 0.24);
    }

    .profile-seasonal-card--winter {
        border-color: rgba(82, 143, 183, 0.22);
    }

    .profile-seasonal-card.is-complete {
        box-shadow: 0 0 0 1px rgba(239, 143, 66, 0.18), 0 12px 26px rgba(239, 143, 66, 0.14);
    }

    .profile-seasonal-card__top {
        display: flex;
        justify-content: space-between;
        gap: 12px;
    }

    .profile-seasonal-card strong,
    .profile-seasonal-card span,
    .profile-seasonal-card em {
        display: block;
    }

    .profile-seasonal-card strong {
        font-weight: 950;
    }

    .profile-seasonal-card span,
    .profile-seasonal-card p {
        color: #65716d;
        font-size: 0.84rem;
        font-weight: 800;
    }

    .profile-seasonal-card em {
        color: #2f6d5f;
        font-style: normal;
        font-weight: 950;
        white-space: nowrap;
    }

    .profile-seasonal-card p {
        margin: 8px 0 0;
    }

    .profile-founder-list {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .profile-founder-badge,
    .profile-founder-empty {
        padding: 14px;
        border: 1px solid rgba(239, 143, 66, 0.22);
        border-radius: 8px;
        background: linear-gradient(180deg, #fff9ee, #ffffff);
        box-shadow: 0 12px 26px rgba(239, 143, 66, 0.10);
    }

    .profile-founder-badge span,
    .profile-founder-badge strong,
    .profile-founder-badge em,
    .profile-founder-empty strong,
    .profile-founder-empty p {
        display: block;
    }

    .profile-founder-badge span {
        color: #ef8f42;
        font-size: 0.72rem;
        font-weight: 950;
        text-transform: uppercase;
    }

    .profile-founder-badge strong,
    .profile-founder-empty strong {
        color: #1f2d29;
        font-weight: 950;
    }

    .profile-founder-badge em,
    .profile-founder-empty p {
        margin-top: 5px;
        color: #65716d;
        font-style: normal;
        font-size: 0.84rem;
        font-weight: 800;
    }

    .profile-founder-empty a {
        display: inline-flex;
        margin-top: 10px;
        color: #2f6d5f;
        font-weight: 950;
        text-decoration: none;
    }

    .profile-stamp-summary {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 8px;
        margin-bottom: 12px;
    }

    .profile-stamp-summary span {
        padding: 10px;
        border: 1px solid rgba(47, 109, 95, 0.12);
        border-radius: 8px;
        background: #f7fbf8;
        color: #65716d;
        font-size: 0.78rem;
        font-weight: 850;
    }

    .profile-stamp-summary strong {
        display: block;
        color: #1f2d29;
        font-size: 1.15rem;
        font-weight: 950;
    }

    .profile-stamp-book {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .profile-stamp {
        display: grid;
        grid-template-columns: 54px 1fr;
        gap: 10px;
        align-items: center;
        min-width: 0;
        padding: 10px;
        border: 1px solid rgba(47, 109, 95, 0.12);
        border-radius: 8px;
        background: #ffffff;
    }

    .profile-stamp__mark {
        display: grid;
        width: 54px;
        aspect-ratio: 1;
        place-items: center;
        border-radius: 999px;
        background: #eef7ed;
        color: #2f6d5f;
        font-size: 1.35rem;
        font-weight: 950;
        box-shadow: inset 0 0 0 3px rgba(255,255,255,0.72);
    }

    .profile-stamp--rare .profile-stamp__mark {
        background: #e9f2ff;
