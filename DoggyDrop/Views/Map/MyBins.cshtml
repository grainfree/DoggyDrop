@model IEnumerable<DoggyDrop.Models.TrashBin>

@{
    ViewData["Title"] = "Moji kosi";
    var bins = Model
        .OrderByDescending(bin => bin.DateAdded)
        .ToList();
    var approvedCount = bins.Count(bin => bin.IsApproved);
    var pendingCount = bins.Count - approvedCount;
    var totalUses = bins.Sum(bin => bin.UsedCount);
    var usefulVotes = bins.Sum(bin => bin.UsefulVotes);
}

<section class="app-page my-bins-page">
    <header class="my-bins-hero">
        <div>
            <span>Prispevki skupnosti</span>
            <h1>Moji kosi</h1>
            <p>Pregled dodanih lokacij, statusa odobritve in uporabnosti v aplikaciji.</p>
        </div>
        <a asp-controller="Map" asp-action="Add">Dodaj kos</a>
    </header>

    <div class="my-bins-stats">
        <article>
            <strong>@bins.Count</strong>
            <span>Skupaj</span>
        </article>
        <article>
            <strong>@approvedCount</strong>
            <span>Odobreni</span>
        </article>
        <article>
            <strong>@pendingCount</strong>
            <span>V pregledu</span>
        </article>
        <article>
            <strong>@totalUses</strong>
            <span>Uporab</span>
        </article>
    </div>

    <article class="my-bins-progress">
        <div>
            <strong>Bin Hero</strong>
            <span>@Math.Min(approvedCount, 10) / 10 odobrenih kosev</span>
        </div>
        <div class="my-bins-progress__bar">
            <span style="width: @(Math.Min(approvedCount, 10) * 10)%"></span>
        </div>
    </article>

    @if (bins.Count == 0)
    {
        <article class="my-bins-empty">
            <h2>Se brez dodanih kosev</h2>
            <p>Ko med sprehodom najdes pasji kos, ga dodaj z lokacijo in sliko. Po odobritvi se prikaze na zemljevidu.</p>
            <a asp-controller="Map" asp-action="Add">Dodaj prvi kos</a>
        </article>
    }
    else
    {
        <div class="my-bins-list">
            @foreach (var bin in bins)
            {
                var imageUrl = bin.FullImageUrl;
                <article class="my-bin-card">
                    <div class="my-bin-card__image">
                        @if (!string.IsNullOrWhiteSpace(imageUrl))
                        {
                            <img src="@imageUrl" alt="@bin.Name" />
                        }
                        else
                        {
                            <span>B</span>
                        }
                    </div>

                    <div class="my-bin-card__body">
                        <div class="my-bin-card__header">
                            <div>
                                <h2>@bin.Name</h2>
                                <p>@bin.DateAdded.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>
                            </div>
                            <span class="my-bin-card__status @(bin.IsApproved ? "is-approved" : "is-pending")">
                                @(bin.IsApproved ? "Odobreno" : "V pregledu")
                            </span>
                        </div>

                        <div class="my-bin-card__metrics">
                            <span>@bin.UsedCount uporab</span>
                            <span>@bin.FullReports poln</span>
                            <span>@bin.MissingReports manjka</span>
                            <span>@bin.UsefulVotes koristen</span>
                            @if (bin.NotUsefulVotes > 0)
                            {
                                <span>@bin.NotUsefulVotes ni OK</span>
                            }
                        </div>

                        <div class="my-bin-card__actions">
                            @if (bin.IsApproved)
                            {
                                <a asp-controller="Map" asp-action="Index">Na zemljevid</a>
                            }
                            <form asp-action="Reject" asp-route-id="@bin.Id" asp-route-returnTo="mybins" method="post">
                                <button type="submit" onclick="return confirm('Si preprican, da zelis izbrisati ta kos?');">Izbrisi</button>
                            </form>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>

<style>
    .my-bins-hero,
    .my-bins-stats article,
    .my-bins-progress,
    .my-bins-empty,
    .my-bin-card {
        border: 1px solid rgba(31, 45, 41, 0.1);
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 12px 28px rgba(31, 45, 41, 0.08);
    }

    .my-bins-hero {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 16px;
        padding: 20px;
    }

    .my-bins-hero span {
        color: #2f6d5f;
        font-size: 0.78rem;
        font-weight: 900;
        text-transform: uppercase;
    }

    .my-bins-hero h1 {
        margin: 4px 0 8px;
        font-size: clamp(2rem, 8vw, 3.2rem);
        font-weight: 950;
        line-height: 1;
    }

    .my-bins-hero p {
        max-width: 520px;
        margin: 0;
        color: #65716d;
    }

    .my-bins-hero a,
    .my-bins-empty a,
    .my-bin-card__actions a,
    .my-bin-card__actions button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        padding: 10px 16px;
        border-radius: 999px;
        font-weight: 900;
        text-decoration: none;
    }

    .my-bins-hero a,
    .my-bins-empty a {
        background: #2f6d5f;
        color: #ffffff;
    }

    .my-bins-stats {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
        margin: 14px 0;
    }

    .my-bins-stats article {
        padding: 16px;
    }

    .my-bins-stats strong,
    .my-bins-stats span {
        display: block;
    }

    .my-bins-stats strong {
        font-size: 1.35rem;
        font-weight: 950;
    }

    .my-bins-stats span {
        color: #65716d;
        font-size: 0.88rem;
        font-weight: 800;
    }

    .my-bins-progress,
    .my-bins-empty {
        margin-bottom: 14px;
        padding: 18px;
    }

    .my-bins-progress {
        display: grid;
        gap: 12px;
    }

    .my-bins-progress strong,
    .my-bins-progress span {
        display: block;
    }

    .my-bins-progress strong {
        font-weight: 950;
    }

    .my-bins-progress span {
        color: #65716d;
        font-weight: 800;
    }

    .my-bins-progress__bar {
        overflow: hidden;
        height: 12px;
        border-radius: 999px;
        background: #eef3ea;
    }

    .my-bins-progress__bar span {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: #2f6d5f;
    }

    .my-bins-empty h2 {
        margin: 0 0 8px;
        font-size: 1.25rem;
        font-weight: 950;
    }

    .my-bins-empty p {
        margin: 0 0 14px;
        color: #65716d;
    }

    .my-bins-list {
        display: grid;
        gap: 12px;
    }

    .my-bin-card {
        display: grid;
        grid-template-columns: 132px 1fr;
        overflow: hidden;
    }

    .my-bin-card__image {
        display: grid;
        min-height: 132px;
        place-items: center;
        background: linear-gradient(135deg, #e7f3e5, #fff3dd);
        color: #2f6d5f;
        font-size: 2.6rem;
        font-weight: 950;
    }

    .my-bin-card__image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .my-bin-card__body {
        display: grid;
        gap: 12px;
        padding: 14px;
    }

    .my-bin-card__header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 10px;
    }

    .my-bin-card__header h2 {
        margin: 0;
        font-size: 1.08rem;
        font-weight: 950;
    }

    .my-bin-card__header p {
        margin: 4px 0 0;
        color: #65716d;
        font-size: 0.84rem;
        font-weight: 750;
    }

    .my-bin-card__status {
        flex: 0 0 auto;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 0.76rem;
        font-weight: 900;
    }

    .my-bin-card__status.is-approved {
        background: #eef7ed;
        color: #2f6d5f;
    }

    .my-bin-card__status.is-pending {
        background: #fff4e5;
        color: #8a5400;
    }

    .my-bin-card__metrics {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }

    .my-bin-card__metrics span {
        padding: 6px 9px;
        border-radius: 999px;
        background: #f3f5f2;
        color: #40514b;
        font-size: 0.78rem;
        font-weight: 850;
    }

    .my-bin-card__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .my-bin-card__actions form {
        margin: 0;
    }

    .my-bin-card__actions a,
    .my-bin-card__actions button {
        min-height: 36px;
        padding: 8px 13px;
        border: 1px solid rgba(47, 109, 95, 0.16);
        background: #ffffff;
        color: #2f6d5f;
        font-size: 0.84rem;
    }

    @@media (max-width: 575.98px) {
        .my-bins-hero {
            align-items: stretch;
            flex-direction: column;
        }

        .my-bins-stats {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .my-bin-card {
            grid-template-columns: 1fr;
        }

        .my-bin-card__image {
            aspect-ratio: 4 / 3;
        }

        .my-bin-card__header {
            flex-direction: column;
        }
    }
</style>
