@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>

    <script>
        const bins = @binsJson;
        let map;
        let userMarker;
        let routeLine;
        let binLayer;
        let dogLayer;
        let parkLayer;
        let waterLayer;
        let cafeLayer;
        let communityLayer;
        let communityHeatRange = "today";
        let exploreFilter = "all";
        let userLocation = null;
        let activeBinId = null;
        const binMarkers = new Map();
        const placeMarkers = new Map();
        const mapSettingsPrefix = "doggydrop.map.";
        const myDogs = @myDogsJson;
        const mapNotificationPreviewCount = document.getElementById("mapNotificationPreviewCount");
        const mapNotificationPreviewItems = document.getElementById("mapNotificationPreviewItems");
        const nearbyDogsList = document.getElementById("nearbyDogsList");
        const nearbyDogsCount = document.getElementById("nearbyDogsCount");
        const communityHeatPanel = document.getElementById("communityHeatPanel");
        const communityHeatRangeLabel = document.getElementById("communityHeatRange");
        const communityActiveWalkers = document.getElementById("communityActiveWalkers");
        const communityPopularParks = document.getElementById("communityPopularParks");
        const communityTrendingRoutes = document.getElementById("communityTrendingRoutes");
        const communityEvents = document.getElementById("communityEvents");
        const mapFounderPrompt = document.getElementById("mapFounderPrompt");
        const mapFounderPromptText = document.getElementById("mapFounderPromptText");

        const placeGroups = {
            parks: [
                { name: "Pasji park Koseze", area: "Ljubljana", address: "Ob Koseskem bajerju", latitude: 46.0689, longitude: 14.4697, type: "park", label: "Pasji park" },
                { name: "Pasji park Stepansko naselje", area: "Ljubljana", address: "Ob Pesarski cesti", latitude: 46.0476, longitude: 14.5515, type: "park", label: "Pasji park" },
                { name: "Pasji park Severni park", area: "Ljubljana", address: "Vilharjeva / Zelezna cesta", latitude: 46.0615, longitude: 14.5210, type: "park", label: "Pasji park" },
                { name: "Pasji park Tivoli", area: "Ljubljana", address: "Tivoli park", latitude: 46.0567, longitude: 14.4965, type: "park", label: "Pasji park" },
                { name: "Pasji park Fuzine", area: "Ljubljana", address: "Fuzinski park", latitude: 46.0519, longitude: 14.5650, type: "park", label: "Pasji park" },
                { name: "Pasji park Bezigrad", area: "Ljubljana", address: "Ob Dunajski cesti", latitude: 46.0742, longitude: 14.5148, type: "park", label: "Pasji park" },
                { name: "Pasji park Vic", area: "Ljubljana", address: "Ob PST poti", latitude: 46.0415, longitude: 14.4769, type: "park", label: "Pasji park" },
                { name: "Pasji park Mostec", area: "Ljubljana", address: "Rekreacijsko obmocje Mostec", latitude: 46.0727, longitude: 14.4723, type: "park", label: "Pasji park" },
                { name: "Pasji park Koper", area: "Obala", address: "Semedela", latitude: 45.5426, longitude: 13.7184, type: "park", label: "Pasji park" },
                { name: "Pasji park Izola", area: "Obala", address: "Ob obalni promenadi", latitude: 45.5365, longitude: 13.6619, type: "park", label: "Pasji park" },
                { name: "Pasji park Lucija", area: "Obala", address: "Lucija center", latitude: 45.5056, longitude: 13.6024, type: "park", label: "Pasji park" },
                { name: "Pasji park Murska Sobota", area: "Prekmurje", address: "Mestni park / sportni del", latitude: 46.6606, longitude: 16.1664, type: "park", label: "Pasji park" },
                { name: "Pasji park Tabor", area: "Maribor", address: "Ob sportnem parku Tabor", latitude: 46.5487, longitude: 15.6453, type: "park", label: "Pasji park" },
                { name: "Pasji park Mestni park", area: "Maribor", address: "Ob robu Mestnega parka", latitude: 46.5625, longitude: 15.6480, type: "park", label: "Pasji park" },
                { name: "Pasji park Pekre", area: "Maribor", address: "Pekre", latitude: 46.5338, longitude: 15.5959, type: "park", label: "Pasji park" },
                { name: "Pasji park Celje", area: "Celje", address: "Ob Savinji", latitude: 46.2387, longitude: 15.2675, type: "park", label: "Pasji park" },
                { name: "Pasji park Lava", area: "Celje", address: "Lava", latitude: 46.2289, longitude: 15.2518, type: "park", label: "Pasji park" },
                { name: "Pasji park Kranj", area: "Kranj", address: "Zlato polje", latitude: 46.2449, longitude: 14.3617, type: "park", label: "Pasji park" },
                { name: "Pasji park Strazisce", area: "Kranj", address: "Strazisce", latitude: 46.2508, longitude: 14.3325, type: "park", label: "Pasji park" },
                { name: "Pasji park Novo mesto", area: "Novo mesto", address: "Portoval", latitude: 45.7998, longitude: 15.1771, type: "park", label: "Pasji park" },
                { name: "Pasji park Nova Gorica", area: "Nova Gorica", address: "Ob sportnem centru", latitude: 45.9561, longitude: 13.6482, type: "park", label: "Pasji park" },
                { name: "Pasji park Ptuj", area: "Ptuj", address: "Ranca Ptuj", latitude: 46.4216, longitude: 15.8788, type: "park", label: "Pasji park" },
                { name: "Pasji park Slovenj Gradec", area: "Slovenj Gradec", address: "Sportni park", latitude: 46.5095, longitude: 15.0808, type: "park", label: "Pasji park" },
                { name: "Pasji park Velenje", area: "Velenje", address: "Ob Velenjskem jezeru", latitude: 46.3622, longitude: 15.1147, type: "park", label: "Pasji park" }
            ],
            water: [
                { name: "Pitnik Lent", latitude: 46.5572, longitude: 15.6467, type: "water", label: "Voda" },
                { name: "Pitnik Tivoli", latitude: 46.0552, longitude: 14.4958, type: "water", label: "Voda" },
                { name: "Pitnik ob Dravi", latitude: 46.5608, longitude: 15.6395, type: "water", label: "Voda" }
            ],
            cafes: [
                { name: "Dog friendly Lent", latitude: 46.5578, longitude: 15.6452, type: "cafe", label: "Cafe" },
                { name: "Dog friendly center Ljubljana", latitude: 46.0511, longitude: 14.5051, type: "cafe", label: "Cafe" },
                { name: "Dog friendly Koper", latitude: 45.5481, longitude: 13.7301, type: "cafe", label: "Cafe" }
            ]
        };

        const nearbyFallbackAreas = [
            { key: "maribor", name: "Maribor", latitude: 46.5547, longitude: 15.6459 },
            { key: "ljubljana", name: "Ljubljana", latitude: 46.0569, longitude: 14.5058 },
            { key: "koper", name: "Koper / Obala", latitude: 45.5481, longitude: 13.7301 },
            { key: "celje", name: "Celje", latitude: 46.2397, longitude: 15.2677 },
            { key: "kranj", name: "Kranj", latitude: 46.2397, longitude: 14.3556 }
        ];

        function createBinIcon(bin) {
            const statusClass = bin.status === "missing"
                ? " map-bin-marker--missing"
                : bin.status === "full"
                    ? " map-bin-marker--full"
                    : "";

            return L.divIcon({
                className: "",
                html: `<span class="map-bin-marker${statusClass}"><span>B</span></span>`,
                iconSize: [42, 42],
                iconAnchor: [21, 21],
                popupAnchor: [0, -22]
            });
        }

        const userIcon = L.icon({
            iconUrl: "/images/jack%20russel%20terrier.png",
            iconSize: [50, 50],
            iconAnchor: [25, 25],
            popupAnchor: [0, -24]
        });

        const dogIcon = L.divIcon({
            className: "",
            html: "<span class=\"map-dog-marker\">D</span>",
            iconSize: [42, 42],
            iconAnchor: [21, 21],
            popupAnchor: [0, -22]
        });

        function createPlaceIcon(type) {
            const label = type === "park" ? "P" : type === "water" ? "W" : "C";
            return L.divIcon({
                className: "",
                html: `<span class="map-place-marker map-place-marker--${type}"><span>${label}</span></span>`,
                iconSize: [40, 40],
                iconAnchor: [20, 20],
                popupAnchor: [0, -22]
            });
        }

        document.addEventListener("DOMContentLoaded", initMap);

        function initMap() {
            map = L.map("map").setView([46.5547, 15.6459], 14);

            L.tileLayer("https://{s}.basemaps.cartocdn.com/rastertiles/voyager_nolabels/{z}/{x}/{y}{r}.png", {
                subdomains: "abcd",
                maxZoom: 20,
                attribution: "&copy; OpenStreetMap contributors &copy; CARTO"
            }).addTo(map);

            L.tileLayer("https://{s}.basemaps.cartocdn.com/rastertiles/voyager_only_labels/{z}/{x}/{y}{r}.png", {
                subdomains: "abcd",
                maxZoom: 20,
                pane: "tilePane",
                opacity: 0.72,
                attribution: "&copy; OpenStreetMap contributors &copy; CARTO"
            }).addTo(map);

            binLayer = L.layerGroup().addTo(map);
            bins.forEach(bin => {
                const marker = L.marker([bin.latitude, bin.longitude], { icon: createBinIcon(bin) })
                    .addTo(binLayer);
                marker.on("click", event => {
                    if (event.originalEvent) {
                        L.DomEvent.stopPropagation(event.originalEvent);
                    }
                    openBinDetail(bin);
                });
                binMarkers.set(Number(bin.id), marker);
            });

            parkLayer = buildPlaceLayer(placeGroups.parks);
            waterLayer = buildPlaceLayer(placeGroups.water);
            cafeLayer = buildPlaceLayer(placeGroups.cafes);
            dogLayer = L.layerGroup();
            communityLayer = L.layerGroup().addTo(map);
            parkLayer.addTo(map);
            waterLayer.addTo(map);
            cafeLayer.addTo(map);
            loadNearbyDogs();
            loadCommunityHeatmap();

            if (bins.length > 0) {
                const bounds = L.latLngBounds(bins.map(bin => [bin.latitude, bin.longitude]));
                map.fitBounds(bounds.pad(0.2), { maxZoom: 16 });
            }

            requestAnimationFrame(() => {
                map.invalidateSize();
                if (bins.length > 0) {
                    const bounds = L.latLngBounds(bins.map(bin => [bin.latitude, bin.longitude]));
                    map.fitBounds(bounds.pad(0.2), { maxZoom: 16 });
                }
            });

            setTimeout(() => map.invalidateSize(), 300);
            map.on("click", closeBinDetail);
            document.getElementById("binDetailClose")?.addEventListener("click", closeBinDetail);

            document.getElementById("showBins").addEventListener("change", function (event) {
                if (event.target.checked) {
                    binLayer.addTo(map);
                } else {
                    binLayer.remove();
                }
                saveMapSetting("showBins", event.target.checked);
            });

            wireLayerToggle("showParks", parkLayer);
            wireLayerToggle("showWater", waterLayer);
            wireLayerToggle("showCafes", cafeLayer);
            wireLayerToggle("showDogs", dogLayer);
            wireLayerToggle("showCommunity", communityLayer, communityHeatPanel);
            document.getElementById("filterToggle").addEventListener("click", openFilterPanel);
            document.getElementById("filterClose").addEventListener("click", closeFilterPanel);
            document.getElementById("exploreToggle").addEventListener("click", openExplorePanel);
            document.getElementById("exploreClose").addEventListener("click", closeExplorePanel);
            document.getElementById("exploreSearch").addEventListener("input", renderExploreList);
            document.querySelectorAll("[data-explore-filter]").forEach(button => {
                button.addEventListener("click", () => {
                    exploreFilter = button.dataset.exploreFilter || "all";
                    document.querySelectorAll("[data-explore-filter]").forEach(item => item.classList.remove("is-active"));
                    button.classList.add("is-active");
                    renderExploreList();
                });
            });
            document.querySelectorAll("[data-heatmap-range]").forEach(button => {
                button.addEventListener("click", () => {
                    communityHeatRange = button.dataset.heatmapRange || "today";
                    document.querySelectorAll("[data-heatmap-range]").forEach(item => item.classList.remove("is-active"));
                    button.classList.add("is-active");
                    loadCommunityHeatmap();
                });
            });
            document.getElementById("parkCountLabel").textContent = `(${placeGroups.parks.length})`;
            applySavedMapSettings();
            renderExploreList();
            refreshNotificationPreview();
            window.setInterval(refreshNotificationPreview, 60000);
            updateFounderPrompt();
            map.on("moveend", updateFounderPrompt);
            focusMapNearUser();

            if (!window.isSecureContext) {
                document.getElementById("mapLocationWarning").hidden = false;
            }
        }

        function focusMapNearUser() {
            if (!navigator.geolocation || !window.isSecureContext) {
                return;
            }

            navigator.geolocation.getCurrentPosition(position => {
                userLocation = {
                    lat: position.coords.latitude,
                    lng: position.coords.longitude
                };

                if (userMarker) {
                    userMarker.setLatLng([userLocation.lat, userLocation.lng]);
                } else {
                    userMarker = L.marker([userLocation.lat, userLocation.lng], { icon: userIcon })
                        .addTo(map)
                        .bindPopup("Tvoja lokacija");
                }

                map.setView([userLocation.lat, userLocation.lng], 15, { animate: true });
                updateFounderPrompt();
                loadNearbyDogs();
                renderNearbySuggestions();
            }, () => {
                if (bins.length > 0) {
                    const bounds = L.latLngBounds(bins.map(bin => [bin.latitude, bin.longitude]));
                    map.fitBounds(bounds.pad(0.2), { maxZoom: 16 });
                }
            }, {
                enableHighAccuracy: false,
                timeout: 5000,
                maximumAge: 300000
            });
        }

        async function refreshNotificationPreview() {
            try {
                const response = await fetch("/api/notifications/center", {
                    headers: { "X-Requested-With": "XMLHttpRequest" }
                });

                if (!response.ok) {
                    return;
                }

                const data = await response.json();
                const unreadCount = Number(data.unreadCount || 0);
                const latestUnread = Array.isArray(data.latestUnread) ? data.latestUnread : [];
                const smart = Array.isArray(data.smart) ? data.smart : [];
                const previewItems = latestUnread.slice(0, 2).map(item => ({
                    title: item.title,
                    body: item.body
                }));

                if (previewItems.length < 2) {
                    smart.slice(0, 2 - previewItems.length).forEach(item => {
                        previewItems.push({
                            title: item.title,
                            body: item.body
                        });
                    });
                }

                mapNotificationPreviewCount.textContent = unreadCount > 0
                    ? `${unreadCount} novih`
                    : `${smart.length} smart`;

                if (previewItems.length === 0) {
                    mapNotificationPreviewItems.innerHTML = `
                        <div class="map-notification-preview__item">
                            <strong>Miren trenutek</strong>
                            <p>Trenutno ni novih obvestil ali smart predlogov.</p>
                        </div>
                    `;
                    return;
                }

                mapNotificationPreviewItems.innerHTML = previewItems.map(item => `
                    <div class="map-notification-preview__item">
                        <strong>${escapeHtml(item.title || "DoggyDrop")}</strong>
                        <p>${escapeHtml(item.body || "")}</p>
                    </div>
                `).join("");
            } catch {
            }
        }

        function buildPlaceLayer(places) {
            const layer = L.layerGroup();
            places.forEach(place => {
                const marker = L.marker([place.latitude, place.longitude], { icon: createPlaceIcon(place.type) })
                    .addTo(layer)
                    .bindPopup(`
                        <div class="bin-popup">
                            <div class="bin-popup__title">${escapeHtml(place.name)}</div>
                            <div class="bin-popup__meta">
                                ${escapeHtml(place.label)}${place.area ? ` - ${escapeHtml(place.area)}` : ""}<br>
                                ${place.address ? escapeHtml(place.address) : "Lokacija na zemljevidu"}
                            </div>
                            ${buildParkVisitControls(place)}
                            <a class="bin-popup__nav" href="${buildNavigationUrl(place.latitude, place.longitude)}" target="_blank" rel="noopener">Odpri navigacijo</a>
                        </div>
                    `);
                placeMarkers.set(getPlaceKey(place), marker);
            });
            return layer;
        }

        function buildParkVisitControls(place) {
            if (place.type !== "park") {
                return "";
            }

            if (!myDogs || myDogs.length === 0) {
                return `
                    <div class="park-visit-box">
                        <span>Za belezenje obiska najprej dodaj psa.</span>
                        <a href="/Dogs/Create">Dodaj psa</a>
                    </div>
                `;
            }

            const placeKey = getPlaceKey(place);
            const options = myDogs
                .map(dog => `<option value="${Number(dog.id ?? dog.Id)}">${escapeHtml(dog.name ?? dog.Name ?? "Pes")}</option>`)
                .join("");

            return `
                <div class="park-visit-box">
                    <label for="parkDog${escapeAttribute(placeKey)}">Obisk parka</label>
                    <select id="parkDog${escapeAttribute(placeKey)}">${options}</select>
                    <button type="button" onclick="recordParkVisit('${escapeAttribute(placeKey)}')">Zabelezi obisk</button>
                    <span id="parkVisitFeedback${escapeAttribute(placeKey)}"></span>
                </div>
            `;
        }

        async function recordParkVisit(placeKey) {
            const place = [...placeGroups.parks, ...placeGroups.water, ...placeGroups.cafes]
                .find(candidate => getPlaceKey(candidate) === placeKey);
            const feedback = document.getElementById(`parkVisitFeedback${placeKey}`);
            const dogSelect = document.getElementById(`parkDog${placeKey}`);

            if (!place || !dogSelect) {
                return;
            }

            if (feedback) {
                feedback.textContent = "Shranjujem ...";
            }

            try {
                const response = await fetch("/Map/ParkVisit", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "X-Requested-With": "XMLHttpRequest"
                    },
                    body: JSON.stringify({
                        dogId: Number(dogSelect.value),
                        parkName: place.name,
                        area: place.area,
                        address: place.address,
                        placeKey,
                        latitude: place.latitude,
                        longitude: place.longitude
                    })
                });

                if (response.status === 401 || response.redirected) {
                    window.location.href = "/Identity/Account/Login";
                    return;
                }

                if (!response.ok) {
                    throw new Error("Obiska ni bilo mogoce shraniti.");
                }

                const result = await response.json();
                if (feedback) {
                    feedback.textContent = result.saved
                        ? `${escapeHtml(result.name)}: obisk shranjen (${result.visitCount}x).`
                        : `Obisk je bil ze shranjen pred kratkim (${result.visitCount}x).`;
                }
            } catch (error) {
                if (feedback) {
                    feedback.textContent = error.message;
                }
            }
        }

        function wireLayerToggle(inputId, layer, panel) {
            document.getElementById(inputId).addEventListener("change", function (event) {
                if (event.target.checked) {
                    layer.addTo(map);
                    if (panel) {
                        panel.hidden = false;
                    }
                } else {
                    layer.remove();
                    if (panel) {
                        panel.hidden = true;
                    }
                }
                saveMapSetting(inputId, event.target.checked);
            });
        }

        function applySavedMapSettings() {
            applyLayerSetting("showBins", binLayer, true);
            applyLayerSetting("showParks", parkLayer, true);
            applyLayerSetting("showWater", waterLayer, true);
            applyLayerSetting("showCafes", cafeLayer, true);
            applyLayerSetting("showDogs", dogLayer, false);
            applyLayerSetting("showCommunity", communityLayer, true, communityHeatPanel);
        }

        async function loadNearbyDogs() {
            try {
                const query = userLocation
                    ? `?latitude=${encodeURIComponent(userLocation.lat)}&longitude=${encodeURIComponent(userLocation.lng)}&radiusKm=8`
                    : "";
                const response = await fetch(`/api/dogs/nearby${query}`);
                if (!response.ok) {
                    return;
                }

                const dogs = await response.json();
                dogLayer.clearLayers();
                dogs.forEach(dog => {
                    L.marker([dog.latitude, dog.longitude], { icon: dogIcon })
                        .addTo(dogLayer)
                        .bindPopup(buildDogPopupContent(dog));
                });
                renderNearbyDogCards(dogs);

                if (getMapSetting("showDogs", false)) {
                    dogLayer.addTo(map);
                }
            } catch {
                // Social layer is optional during local testing.
            }
        }

        function applyLayerSetting(inputId, layer, fallback, panel) {
            const enabled = getMapSetting(inputId, fallback);
            document.getElementById(inputId).checked = enabled;
            if (enabled) {
                layer.addTo(map);
                if (panel) {
                    panel.hidden = false;
                }
            } else {
                layer.remove();
                if (panel) {
                    panel.hidden = true;
                }
            }
        }

        function applyCheckboxSetting(inputId, fallback) {
            document.getElementById(inputId).checked = getMapSetting(inputId, fallback);
        }

        async function loadCommunityHeatmap() {
            if (!communityLayer) {
                return;
            }

            try {
                const response = await fetch(`/api/community-map/heatmap?range=${encodeURIComponent(communityHeatRange)}`, {
                    headers: { "X-Requested-With": "XMLHttpRequest" }
                });

                if (!response.ok) {
                    return;
                }

                const data = await response.json();
                renderCommunityHeatmap(data);
            } catch {
            }
        }

        function renderCommunityHeatmap(data) {
            communityLayer.clearLayers();
            const hotspots = Array.isArray(data.hotspots) ? data.hotspots : [];

            hotspots.forEach(hotspot => {
                const type = hotspot.type || "route";
                const count = Number(hotspot.count || 0);
                const intensity = Math.max(0.25, Math.min(1, Number(hotspot.intensity || 0.4)));
                const size = Math.round(34 + intensity * 28);
                const icon = L.divIcon({
                    className: "",
                    html: `<span class="map-heat-marker map-heat-marker--${escapeAttribute(type)}">${count > 1 ? count : ""}</span>`,
                    iconSize: [size, size],
                    iconAnchor: [size / 2, size / 2],
                    popupAnchor: [0, -size / 2]
                });

                L.marker([hotspot.latitude, hotspot.longitude], { icon })
                    .addTo(communityLayer)
                    .bindPopup(`
                        <div class="bin-popup">
                            <div class="bin-popup__title">${escapeHtml(hotspot.title || "Community hotspot")}</div>
                            <div class="bin-popup__meta">${escapeHtml(hotspot.subtitle || "")}</div>
                        </div>
                    `);

                L.circle([hotspot.latitude, hotspot.longitude], {
                    radius: 120 + intensity * 360,
                    color: getHeatColor(type),
                    fillColor: getHeatColor(type),
                    fillOpacity: 0.10 + intensity * 0.12,
                    opacity: 0.16,
                    weight: 1
                }).addTo(communityLayer);
            });

            communityHeatRangeLabel.textContent = getHeatRangeLabel(data.range || communityHeatRange);
            communityActiveWalkers.textContent = Number(data.activeWalkers || 0).toString();
            communityPopularParks.textContent = Number(data.popularParks || 0).toString();
            communityTrendingRoutes.textContent = Number(data.trendingRoutes || 0).toString();

            const events = Array.isArray(data.events) ? data.events : [];
            communityEvents.innerHTML = events.length
                ? events.map(item => `
                    <div class="map-community-event">
                        <strong>${escapeHtml(item.title || "DoggyDrop")}</strong>
                        <span>${escapeHtml(item.subtitle || "")}</span>
                    </div>
                `).join("")
                : `<p>Danes je se mirno. Prvi sprehod bo prizgal heatmap.</p>`;
        }

        function getHeatColor(type) {
            if (type === "active") return "#e05b43";
            if (type === "park") return "#ef8f42";
            if (type === "dog") return "#6c5ce7";
            return "#2f6d5f";
        }

        function getHeatRangeLabel(range) {
            if (range === "week") return "This week";
            if (range === "evening") return "Evening";
            return "Today";
        }

