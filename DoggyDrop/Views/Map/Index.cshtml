        async function sendQuickPlaydateInvite(targetDogId) {
            const sourceSelect = document.getElementById(`quickInviteDog${targetDogId}`);
            const feedback = document.getElementById(`quickInviteFeedback${targetDogId}`);

            if (!sourceSelect) {
                return;
            }

            if (feedback) {
                feedback.textContent = "Posiljam ...";
            }

            try {
                const response = await fetch("/api/playdates/quick-invite", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "X-Requested-With": "XMLHttpRequest"
                    },
                    body: JSON.stringify({
                        sourceDogId: Number(sourceSelect.value),
                        targetDogId,
                        locationLabel: userLocation ? "trenutna lokacija" : "DoggyDrop mapa",
                        energyLevel: "Srednja",
                        message: "Hitro povabilo iz mape."
                    })
                });

                if (response.status === 401 || response.redirected) {
                    window.location.href = "/Identity/Account/Login";
                    return;
                }

                if (!response.ok) {
                    const result = await response.json().catch(() => null);
                    throw new Error(result?.message || "Povabila ni bilo mogoce poslati.");
                }

                if (feedback) {
                    feedback.textContent = "Povabilo poslano.";
                }
            } catch (error) {
                if (feedback) {
                    feedback.textContent = error.message;
                }
            }
        }

        async function sendBinAction(binId, action) {
            const feedback = document.getElementById(`binFeedback${binId}`);
            if (feedback) {
                feedback.textContent = "Shranjujem ...";
            }

            try {
                const response = await fetch(`/Map/BinAction/${binId}?action=${encodeURIComponent(action)}`, {
                    method: "POST",
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    }
                });

                if (response.status === 401 || response.redirected) {
                    window.location.href = "/Identity/Account/Login";
                    return;
                }

                if (!response.ok) {
                    throw new Error("Akcije ni bilo mogoce shraniti.");
                }

                const updated = await response.json();
                const bin = bins.find(item => Number(item.id) === Number(binId));
                if (!bin) {
                    return;
                }

                Object.assign(bin, {
                    usedCount: updated.usedCount,
                    fullReports: updated.fullReports,
                    missingReports: updated.missingReports,
                    usefulVotes: updated.usefulVotes,
                    notUsefulVotes: updated.notUsefulVotes,
                    status: updated.missingReports >= 2 ? "missing" : updated.fullReports >= 2 ? "full" : "ok",
                    lastUsedAt: updated.lastUsedAt,
                    lastReportedAt: updated.lastReportedAt
                });

                const marker = binMarkers.get(Number(binId));
                if (marker) {
                    marker.setIcon(createBinIcon(bin));
                }

                if (activeBinId === Number(binId)) {
                    openBinDetail(bin);
                }

                const nextFeedback = document.getElementById(`binFeedback${binId}`);
                if (nextFeedback) {
                    nextFeedback.textContent = "Shranjeno.";
                }
            } catch (error) {
                if (feedback) {
                    feedback.textContent = error.message;
                } else {
                    alert(error.message);
                }
            }
        }

        function findNearestTrashBin() {
            if (!navigator.geolocation) {
                alert("Geolokacija ni podprta v tvojem brskalniku.");
                return;
            }

            if (!window.isSecureContext) {
                document.getElementById("mapLocationWarning").hidden = false;
                alert("Lokacija na tej povezavi ni dovoljena. Za GPS na telefonu bova kasneje uredila HTTPS.");
                return;
            }

            if (bins.length === 0) {
                alert("Trenutno ni odobrenih kosev.");
                return;
            }

            navigator.geolocation.getCurrentPosition(position => {
                userLocation = {
                    lat: position.coords.latitude,
                    lng: position.coords.longitude
                };

                if (userMarker) {
                    userMarker.setLatLng([userLocation.lat, userLocation.lng]);
                } else {
                    userMarker = L.marker([userLocation.lat, userLocation.lng], { icon: userIcon })
                        .addTo(map)
                        .bindPopup("Tvoja lokacija");
                }

                loadNearbyDogs();

                fetch(`/Map/GetBestBin?latitude=${encodeURIComponent(userLocation.lat)}&longitude=${encodeURIComponent(userLocation.lng)}`, {
                    headers: { "X-Requested-With": "XMLHttpRequest" }
                })
                .then(response => {
                    if (!response.ok) {
                        throw new Error("Najboljsega kosa ni bilo mogoce poiskati.");
                    }

                    return response.json();
                })
                .then(nearestBin => {
                    if (routeLine) {
                        routeLine.remove();
                    }

                    routeLine = L.polyline(
                        [
                            [userLocation.lat, userLocation.lng],
                            [nearestBin.latitude, nearestBin.longitude]
                        ],
                        { color: "#00796B", weight: 6, opacity: 0.9 }
                    ).addTo(map);

                    map.fitBounds(routeLine.getBounds().pad(0.25));

                    const distance = formatDistance(nearestBin.distanceMeters);
                    const walkingMinutes = Math.max(1, Math.round(nearestBin.distanceMeters / 83));
                    const panel = document.getElementById("directionsPanel");
                    panel.style.display = "block";
                    panel.innerHTML = `
                        <strong>Predlagan kos:</strong> ${escapeHtml(nearestBin.name)}<br>
                        <strong>Cas hoje:</strong> priblizno ${walkingMinutes} min<br>
                        <strong>Razdalja:</strong> ${distance}<br>
                        <strong>Zanesljivost:</strong> ${Number(nearestBin.reliabilityScore || 0)}/100
                    `;
                    renderNearbySuggestions();
                })
                .catch(error => alert(error.message));
            }, () => alert("Napaka pri pridobivanju lokacije."), {
                enableHighAccuracy: true,
                maximumAge: 0,
                timeout: 10000
            });
        }

        function locateAndSuggestWalks(flyToLocation = true) {
            const status = document.getElementById("nearbySuggestionsStatus");

            if (!navigator.geolocation) {
                status.textContent = "Ta brskalnik ne podpira geolokacije.";
                renderNearbySuggestions();
                return;
            }

            if (!window.isSecureContext) {
                status.textContent = "Za tocen GPS na telefonu bo treba uporabiti HTTPS povezavo.";
                renderNearbySuggestions();
                return;
            }

            status.textContent = "Pridobivam tvojo lokacijo ...";

            navigator.geolocation.getCurrentPosition(position => {
                userLocation = {
                    lat: position.coords.latitude,
                    lng: position.coords.longitude
                };
                loadNearbyDogs();

                if (userMarker) {
                    userMarker.setLatLng([userLocation.lat, userLocation.lng]);
                } else {
                    userMarker = L.marker([userLocation.lat, userLocation.lng], { icon: userIcon })
                        .addTo(map)
                        .bindPopup("Tvoja lokacija");
                }

                if (flyToLocation) {
                    map.setView([userLocation.lat, userLocation.lng], 16, { animate: true });
                }

                status.textContent = "Predlogi so pripravljeni iz tvoje trenutne lokacije.";
                renderNearbySuggestions();
            }, () => {
                status.textContent = "Lokacije ni bilo mogoce pridobiti. Prikazani so predlogi iz centra zemljevida.";
                renderNearbySuggestions();
            }, {
                enableHighAccuracy: true,
                maximumAge: 0,
                timeout: 10000
            });
        }

