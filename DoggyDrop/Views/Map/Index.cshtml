@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success text-center position-fixed top-0 start-50 translate-middle-x mt-3 z-3" style="max-width: 500px;">
        @TempData["SuccessMessage"]
    </div>
}

<button type="button" id="filterToggle" class="map-filter-toggle">Filtri</button>

<section class="map-quick-intro" aria-label="DoggyDrop zemljevid">
    <div class="map-quick-intro__eyebrow">
        <i class="bi bi-heart-pulse-fill" aria-hidden="true"></i>
        <span>DoggyDrop mapa</span>
    </div>
    <h1>Odkrij bližnje sprehode, parke in pasje koše.</h1>
    <p>Tukaj najhitreje začneš sprehod, najdeš najbližji koš in odpreš predloge poti okoli sebe.</p>
</section>

@if (showFirstWalkPrompt)
{
    <section class="map-first-walk-card" aria-label="Prvi sprehod">
        <div class="map-first-walk-card__eyebrow">
            <i class="bi bi-heart-fill" aria-hidden="true"></i>
            <span>Prvi kuža dodan</span>
        </div>
        <h2>Super, @firstDogName je pripravljen za prvi sprehod</h2>
        <p>Zdaj lahko v enem tapu predlagava prvo pot, pogledava bližnje parke ali pa samo hitro začnemo hoditi.</p>
        <a class="btn btn-success map-first-walk-card__cta" asp-controller="Walks" asp-action="Planner">
            <i class="bi bi-play-circle-fill" aria-hidden="true"></i>
            <span>Start walk</span>
        </a>
        <div class="map-first-walk-card__meta">DoggyDrop bo medtem začel beležiti kilometre, značke in najljubše sprehode.</div>
    </section>
}
else if (needsDogOnboarding)
{
    <section class="map-first-dog-card" aria-label="Dodaj prvega psa">
        <div class="map-first-dog-card__eyebrow">
            <i class="bi bi-stars" aria-hidden="true"></i>
            <span>Prvi pasji profil</span>
        </div>
        <h2>@userDisplayName, spoznajmo tvojega kužka</h2>
        <p>Dodaj psa, da DoggyDrop začne delati zate: boljši predlogi sprehodov, osebne statistike, značke in veliko bolj živ profil.</p>
        <div class="map-first-dog-card__chips" aria-label="Predlogi za profil">
            <span>Ime</span>
            <span>Fotka smrčka</span>
