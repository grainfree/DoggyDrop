@model IEnumerable<DoggyDrop.Models.TrashBin>
@using System.Text.Json

@{
    ViewData["Title"] = "Zemljevid";
    ViewData["FullBleed"] = true;
    var json = JsonSerializer.Serialize(
        Model.Select(b => new
        {
            id = b.Id,
            name = b.Name,
            latitude = b.Latitude,
            longitude = b.Longitude,
            date = b.DateAdded.ToString("dd.MM.yyyy"),
            image = b.FullImageUrl,
            user = b.User?.DisplayName ?? "Neznan uporabnik",
            usedCount = b.UsedCount,
            fullReports = b.FullReports,
            missingReports = b.MissingReports,
            usefulVotes = b.UsefulVotes,
            notUsefulVotes = b.NotUsefulVotes,
            reliabilityScore = Math.Clamp(60 + Math.Min(18, b.UsefulVotes * 3) + Math.Min(15, b.UsedCount) - Math.Min(28, b.FullReports * 8) - Math.Min(35, b.MissingReports * 12), 0, 100),
            status = b.MissingReports >= 2 ? "missing" : b.FullReports >= 2 ? "full" : "ok",
            lastUsedAt = b.LastUsedAt.HasValue ? b.LastUsedAt.Value.ToString("dd.MM.yyyy HH:mm") : null,
            lastReportedAt = b.LastReportedAt.HasValue ? b.LastReportedAt.Value.ToString("dd.MM.yyyy HH:mm") : null
        })
    );

    var binsJson = Html.Raw(json);
    var myDogsJson = Html.Raw(JsonSerializer.Serialize(ViewBag.MyDogs ?? Array.Empty<object>()));
    var needsDogOnboarding = ViewBag.NeedsDogOnboarding as bool? == true;
    var userDisplayName = (ViewBag.UserDisplayName as string) ?? "pasjeljubec";
    var showFirstWalkPrompt = TempData["ShowFirstWalkPrompt"] as bool? == true;
    var firstDogName = TempData["FirstDogName"] as string;
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIINfQXh6ULpR5txR9wra5I3BcVsTPY1p3A="
          crossorigin="" />
}

