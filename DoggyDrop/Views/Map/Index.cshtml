        function buildBinDetailImage(imageUrl, name) {
            if (!imageUrl) {
                return `<div class="map-bin-detail__image-placeholder">Fotografija kosa se ni dodana.</div>`;
            }

            const fallback = getBinImageFallback(imageUrl);
            return `<img class="map-bin-detail__image" src="${escapeAttribute(imageUrl)}" data-fallback-src="${escapeAttribute(fallback || "")}" alt="${escapeAttribute(name || "Kos")}" onerror="handleBinImageError(this)">`;
        }

        function getBinImageFallback(imageUrl) {
            const source = String(imageUrl);
            const fileName = source.split("?")[0].split("/").filter(Boolean).pop();
            if (!fileName) {
                return "";
            }

            if (source.startsWith("/uploads/trashbins/")) {
                return `/uploads/${fileName}`;
            }

            if (source.startsWith("/uploads/") && !source.startsWith("/uploads/trashbins/")) {
                return `/uploads/trashbins/${fileName}`;
            }

            return "";
        }

        function handleBinImageError(image) {
            const fallback = image.dataset.fallbackSrc;
            if (fallback && image.src.indexOf(fallback) === -1) {
                image.dataset.fallbackSrc = "";
                image.src = fallback;
                return;
            }

            const placeholder = document.createElement("div");
            placeholder.className = "map-bin-detail__image-placeholder";
            placeholder.textContent = "Fotografija trenutno ni na voljo.";
            image.replaceWith(placeholder);
        }

