        function renderExploreList() {
            const list = document.getElementById("exploreList");
            if (!list) {
                return;
            }

            const search = normalizeSearch(document.getElementById("exploreSearch").value);
            const center = map ? map.getCenter() : L.latLng(46.5547, 15.6459);
            const filterTypes = exploreFilter === "all" ? null : exploreFilter.split(",");
            const items = getExploreItems()
                .filter(item => !filterTypes || filterTypes.includes(item.type))
                .filter(item => !search || normalizeSearch(`${item.name} ${item.area || ""} ${item.address || ""}`).includes(search))
                .map(item => ({
                    ...item,
                    distanceMeters: getDistanceMeters(center.lat, center.lng, item.latitude, item.longitude)
                }))
                .sort((a, b) => a.distanceMeters - b.distanceMeters)
                .slice(0, 40);

            if (items.length === 0) {
                list.innerHTML = `<div class="map-location-warning">Ni zadetkov za ta filter.</div>`;
                return;
            }

            list.innerHTML = items.map(item => `
                <button type="button" class="map-explore-item" onclick="focusExploreItem('${escapeAttribute(item.key)}')">
                    <span class="map-explore-item__icon">${escapeHtml(item.shortLabel)}</span>
                    <span>
                        <strong>${escapeHtml(item.name)}</strong>
                        <span>${escapeHtml(item.subtitle)}</span>
                    </span>
                    <em>${formatDistance(item.distanceMeters)}</em>
                </button>
            `).join("");
        }

        function renderNearbySuggestions() {
            const list = document.getElementById("nearbySuggestionsList");
            const hasPreciseLocation = !!userLocation;
            const fallbackArea = getNearbyFallbackArea();
            const origin = userLocation ?? fallbackArea;
            const nearbyBinLimitMeters = hasPreciseLocation ? 1800 : 3200;
            const ranked = getExploreItems()
                .map(item => ({
                    ...item,
                    distanceMeters: getDistanceMeters(origin.lat, origin.lng, item.latitude, item.longitude)
                }))
                .sort((a, b) => a.distanceMeters - b.distanceMeters);

            const nearestPark = ranked.find(item => item.type === "park");
            const nearestBin = ranked.find(item => item.type === "bin");
            const nearestWater = ranked.find(item => item.type === "water");
            const nearestCafe = ranked.find(item => item.type === "cafe");
            const nearbyBin = nearestBin && nearestBin.distanceMeters <= nearbyBinLimitMeters
                ? nearestBin
                : null;

            const cards = [
                buildNearbySuggestionCard("Hiter park walk", "Kratek izhod s prostorom za vohanje in igro.", nearestPark, [nearbyBin, nearestWater], hasPreciseLocation, fallbackArea),
                nearbyBin
                    ? buildNearbySuggestionCard("Utility walk", "Prakticen mestni krog s kosom in hitro pavzo.", nearbyBin, [nearestCafe, nearestWater], hasPreciseLocation, fallbackArea)
                    : buildCommunityBinCard(hasPreciseLocation, fallbackArea),
                buildNearbySuggestionCard("Daljsi social walk", "Za daljsi sprehod povezi park, vodo in dog-friendly postanek.", nearestPark, [nearestWater, nearestCafe], hasPreciseLocation, fallbackArea)
            ].filter(Boolean);

            list.innerHTML = cards.length > 0
                ? cards.join("")
                : `<div class="map-location-warning">V blizini se ni dovolj tock za samodejni predlog.</div>`;
        }

        function updateFounderPrompt() {
            if (!mapFounderPrompt || !mapFounderPromptText || !map) {
                return;
            }

            const center = userLocation ?? map.getCenter();
            const fallbackArea = getNearbyFallbackArea();
            const nearbyBins = bins.filter(bin =>
                getDistanceMeters(center.lat, center.lng, bin.latitude, bin.longitude) <= 1800);

            mapFounderPrompt.hidden = nearbyBins.length > 0;
            if (nearbyBins.length === 0) {
                mapFounderPromptText.textContent = userLocation
                    ? "V tvoji neposredni okolici še ni potrjenega pasjega koša. Dodaj prvega in postani founder tega območja."
                    : `Okolica ${fallbackArea.name} ima še prostor za prve DoggyDrop koše. Dodaj prvega in odpri območje za skupnost.`;
            }
        }

        function buildNearbySuggestionCard(title, description, anchor, extras, hasPreciseLocation, fallbackArea) {
            if (!anchor) {
                return "";
            }

            const chain = [anchor, ...(extras || []).filter(Boolean)];
            const totalDistance = chain.reduce((sum, item) => sum + (item.distanceMeters || 0), 0);
            const metaText = hasPreciseLocation
                ? formatDistance(totalDistance)
                : `predlog iz ${escapeHtml(fallbackArea.name)}`;

            return `
                <button type="button" class="map-explore-item" onclick="focusExploreItem('${escapeAttribute(anchor.key)}')">
                    <span class="map-explore-item__icon">${escapeHtml(anchor.shortLabel)}</span>
                    <span>
                        <strong>${escapeHtml(title)}</strong>
                        <span>${escapeHtml(description)} ${escapeHtml(chain.map(item => item.shortLabel).join(" - "))}</span>
                    </span>
                    <em>${metaText}</em>
                </button>
            `;
        }

        function buildCommunityBinCard(hasPreciseLocation, fallbackArea) {
            const metaText = hasPreciseLocation
                ? "founder badge opportunity"
                : `pomagaj skupnosti v okolici ${escapeHtml(fallbackArea.name)}`;

            return `
                <a class="map-explore-item map-explore-item--cta" href="/Map/Add">
                    <span class="map-explore-item__icon">+</span>
                    <span class="map-explore-item__content">
                        <strong>Be the first DoggyDrop Explorer here</strong>
                        <span>Ce v tej okolici uporabljas ali opazis dober spot za kos, ga dodaj in si lahko prvi founder tega obmocja.</span>
                        <span class="map-explore-item__meta">${metaText}</span>
                    </span>
                </a>
            `;
        }

        function getNearbyFallbackArea() {
            const center = map ? map.getCenter() : L.latLng(46.5547, 15.6459);
            return nearbyFallbackAreas
                .map(area => ({
                    ...area,
                    distanceMeters: getDistanceMeters(center.lat, center.lng, area.latitude, area.longitude)
                }))
                .sort((a, b) => a.distanceMeters - b.distanceMeters)[0];
        }

        function getExploreItems() {
            const binItems = bins.map(bin => ({
                key: `bin-${Number(bin.id)}`,
                type: "bin",
                shortLabel: "B",
                name: bin.name,
                subtitle: bin.status === "full" ? "Kos je prijavljen kot poln" : bin.status === "missing" ? "Kos je prijavljen kot manjkajoc" : "Pasji kos",
                latitude: bin.latitude,
                longitude: bin.longitude
            }));

            const placeItems = [...placeGroups.parks, ...placeGroups.water, ...placeGroups.cafes].map(place => ({
                key: getPlaceKey(place),
                type: place.type,
                shortLabel: place.type === "park" ? "P" : place.type === "water" ? "W" : "C",
                name: place.name,
                area: place.area,
                address: place.address,
                subtitle: `${place.label}${place.area ? ` - ${place.area}` : ""}`,
                latitude: place.latitude,
                longitude: place.longitude
            }));

            return [...binItems, ...placeItems];
        }

        function focusExploreItem(key) {
            const item = getExploreItems().find(candidate => candidate.key === key);
            if (!item) {
                return;
            }

            const marker = item.type === "bin"
                ? binMarkers.get(Number(key.replace("bin-", "")))
                : placeMarkers.get(key);

            ensureLayerVisible(item.type);
            map.setView([item.latitude, item.longitude], Math.max(map.getZoom(), 16), { animate: true });
            if (marker) {
                marker.openPopup();
            }
        }

        function ensureLayerVisible(type) {
            if (type === "bin") {
                document.getElementById("showBins").checked = true;
                binLayer.addTo(map);
                saveMapSetting("showBins", true);
                return;
            }

            const mapByType = {
                park: ["showParks", parkLayer],
                water: ["showWater", waterLayer],
                cafe: ["showCafes", cafeLayer]
            };

            const setting = mapByType[type];
            if (!setting) {
                return;
            }

            document.getElementById(setting[0]).checked = true;
            setting[1].addTo(map);
            saveMapSetting(setting[0], true);
        }

        function getPlaceKey(place) {
            return `${place.type}-${place.latitude}-${place.longitude}`;
        }

        function buildNavigationUrl(latitude, longitude) {
            return `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(`${latitude},${longitude}`)}`;
        }

        function normalizeSearch(value) {
            return String(value || "")
                .toLowerCase()
                .normalize("NFD")
                .replace(/[\u0300-\u036f]/g, "");
        }

        function showFutureFilterMessage() {
            const warning = document.getElementById("mapLocationWarning");
            warning.hidden = false;
            warning.textContent = "Ta filter je pripravljen, markerje za pse, parke, vodo in kavarne pa dodava v naslednjih korakih.";
        }

        function getDistanceMeters(lat1, lng1, lat2, lng2) {
            const earthRadius = 6371000;
            const dLat = toRadians(lat2 - lat1);
            const dLng = toRadians(lng2 - lng1);
            const a =
                Math.sin(dLat / 2) * Math.sin(dLat / 2) +
                Math.cos(toRadians(lat1)) * Math.cos(toRadians(lat2)) *
                Math.sin(dLng / 2) * Math.sin(dLng / 2);
            return earthRadius * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        }

        function toRadians(value) {
            return value * Math.PI / 180;
        }

        function formatDistance(meters) {
            if (meters >= 1000) {
                return `${(meters / 1000).toFixed(1)} km`;
            }

            return `${Math.round(meters)} m`;
        }

        function escapeHtml(value) {
            return String(value ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        function escapeAttribute(value) {
            return escapeHtml(value).replaceAll("`", "&#096;");
        }
    </script>
}
