@model DoggyDrop.ViewModels.WalkPlannerViewModel
@using System.Globalization
@using System.Text.Json

@{
    ViewData["Title"] = "Planer sprehoda";
    var routePointsJson = Html.Raw(JsonSerializer.Serialize(Model.Route?.RoutePoints ?? []));
    var stopsJson = Html.Raw(JsonSerializer.Serialize(Model.Route?.Stops ?? []));
    var latitudeValue = Model.Latitude?.ToString("0.######", CultureInfo.InvariantCulture) ?? string.Empty;
    var longitudeValue = Model.Longitude?.ToString("0.######", CultureInfo.InvariantCulture) ?? string.Empty;
    var binStop = Model.Route?.Stops.FirstOrDefault(stop => stop.Type == "bin");
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIINfQXh6ULpR5txR9wra5I3BcVsTPY1p3A="
          crossorigin="" />
}

<section class="app-page walk-planner-page">
    <header class="app-page__header walk-planner-hero">
        <div>
            <h1 class="app-page__title">Planer sprehoda</h1>
            <p class="app-page__lead">Izberi hiter predlog. GPS je privzet, koši v bližini pa se samodejno vključijo v pot.</p>
        </div>
        <a class="btn btn-outline-secondary rounded-pill" asp-controller="Walks" asp-action="Index">Sprehodi</a>
    </header>

    <form class="walk-planner-form walk-planner-form--quick" asp-controller="Walks" asp-action="Planner" method="get" id="walkPlannerForm">
        <input type="hidden" id="plannerLatitude" name="latitude" value="@latitudeValue" />
        <input type="hidden" id="plannerLongitude" name="longitude" value="@longitudeValue" />
        <input type="hidden" id="distanceKm" name="distanceKm" value="@Model.TargetDistanceKm.ToString(CultureInfo.InvariantCulture)" />
        <input type="hidden" id="walkStyle" name="walkStyle" value="@Model.WalkStyle" />
        <input type="hidden" id="includeBins" name="includeBins" value="@Model.IncludeBins.ToString().ToLowerInvariant()" />
        <input type="hidden" id="includePark" name="includePark" value="@Model.IncludePark.ToString().ToLowerInvariant()" />
        <input type="hidden" id="includeWater" name="includeWater" value="@Model.IncludeWater.ToString().ToLowerInvariant()" />
        <input type="hidden" id="includeDogFriendly" name="includeDogFriendly" value="@Model.IncludeDogFriendly.ToString().ToLowerInvariant()" />

        <div class="walk-planner-toolbar">
            <div>
                <label for="dogId">Pes</label>
                <select id="dogId" name="dogId">
                    @foreach (var dog in Model.Dogs)
                    {
                        <option value="@dog.Id" selected="@(Model.SelectedDogId == dog.Id)">@dog.Name</option>
                    }
                </select>
            </div>
            <div>
                <label for="dogEnergy">Energija</label>
                <select id="dogEnergy" name="dogEnergy">
                    <option value="auto" selected="@(Model.DogEnergy == "auto")">Auto</option>
                    <option value="low" selected="@(Model.DogEnergy == "low")">Mirna</option>
                    <option value="high" selected="@(Model.DogEnergy == "high")">Aktivna</option>
                </select>
            </div>
            <div class="walk-planner-location">
                <label>Izhodišče</label>
                <button type="button" id="usePlannerLocation" class="walk-planner-location__button">Moja lokacija</button>
                <span id="plannerLocationStatus">
                    @(Model.UsesCurrentLocation ? "GPS je aktiven. Predlog je iz tvoje lokacije." : "GPS se bo poskusil vklopiti samodejno.")
                </span>
            </div>
        </div>

        <div class="walk-planner-presets" aria-label="Hitri predlogi sprehoda">
            @foreach (var preset in Model.Presets)
            {
                var isActive = Math.Abs(Model.TargetDistanceKm - preset.DistanceKm) < 0.05
                    && string.Equals(Model.WalkStyle, preset.WalkStyle, StringComparison.OrdinalIgnoreCase);
                <button type="button"
                        class="walk-planner-preset @(isActive ? "is-active" : "")"
                        data-distance="@preset.DistanceKm.ToString(CultureInfo.InvariantCulture)"
                        data-style="@preset.WalkStyle"
                        data-bins="@preset.IncludeBins.ToString().ToLowerInvariant()"
                        data-park="@preset.IncludePark.ToString().ToLowerInvariant()"
                        data-water="@preset.IncludeWater.ToString().ToLowerInvariant()"
                        data-dog-friendly="@preset.IncludeDogFriendly.ToString().ToLowerInvariant()">
                    <strong>@preset.Title</strong>
                    <span>@preset.Subtitle</span>
                    <em>@preset.DistanceKm.ToString("0.#") km</em>
                </button>
            }
        </div>

        <details class="walk-planner-advanced">
            <summary>Rezervno območje, če GPS ni dovoljen</summary>
            <div class="walk-planner-advanced__grid">
                <div>
                    <label for="area">Fallback območje</label>
                    <select id="area" name="area">
                        @foreach (var area in Model.Areas)
                        {
                            <option value="@area.Key" selected="@(Model.AreaKey == area.Key)">@area.Name</option>
                        }
                    </select>
                </div>
                <button type="submit">Ustvari iz fallback območja</button>
            </div>
        </details>
    </form>

    @if (binStop != null)
    {
        <aside class="walk-planner-nearby-bin">
            <strong>Koš je vključen v pot</strong>
            <span>@binStop.Name je na predlagani trasi, če ga med sprehodom potrebuješ.</span>
        </aside>
    }

    @if (Model.Route != null)
    {
        <section class="walk-planner-layout">
            <article class="walk-planner-map-card">
                <div class="walk-planner-summary">
                    <div>
                        <h2>@Model.Route.Title</h2>
                        <p>@Model.Route.Summary</p>
                    </div>
                    <div>
                        <strong>@Model.Route.EstimatedDistanceKm.ToString("0.0") km</strong>
                        <span>~@Model.Route.EstimatedMinutes min</span>
                    </div>
                </div>
                <div class="walk-planner-map-frame">
                    <div id="plannerMap"></div>
                </div>
                <div class="walk-planner-start">
                    <form asp-controller="Walks" asp-action="SavePlan" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="dogId" value="@Model.SelectedDogId" />
                        <input type="hidden" name="area" value="@Model.AreaKey" />
                        <input type="hidden" name="latitude" value="@latitudeValue" />
                        <input type="hidden" name="longitude" value="@longitudeValue" />
                        <input type="hidden" name="distanceKm" value="@Model.TargetDistanceKm.ToString(CultureInfo.InvariantCulture)" />
                        <input type="hidden" name="walkStyle" value="@Model.WalkStyle" />
                        <input type="hidden" name="dogEnergy" value="@Model.DogEnergy" />
                        <input type="hidden" name="includeBins" value="@Model.IncludeBins.ToString().ToLowerInvariant()" />
                        <input type="hidden" name="includePark" value="@Model.IncludePark.ToString().ToLowerInvariant()" />
                        <input type="hidden" name="includeWater" value="@Model.IncludeWater.ToString().ToLowerInvariant()" />
                        <input type="hidden" name="includeDogFriendly" value="@Model.IncludeDogFriendly.ToString().ToLowerInvariant()" />
                        <button type="submit" class="walk-planner-start__secondary">
                            @(Model.Route.SavedPlanId.HasValue ? "Shrani kot nov plan" : "Shrani plan")
                        </button>
                    </form>
                    @if (Model.SelectedDogId.HasValue)
                    {
                        <form asp-controller="Walks" asp-action="Start" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="dogId" value="@Model.SelectedDogId.Value" />
                            @if (Model.Route.SavedPlanId.HasValue)
                            {
                                <input type="hidden" name="plannedWalkId" value="@Model.Route.SavedPlanId.Value" />
                            }
                            <button type="submit">Začni ta sprehod</button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Dogs" asp-action="Create">Dodaj psa za začetek sprehoda</a>
                    }
                </div>
            </article>

            <aside class="walk-planner-stops">
                <h2>Postanki</h2>
                @foreach (var stop in Model.Route.Stops)
                {
                    <article>
                        <span>@stop.Order</span>
                        <div>
                            <strong>@stop.Name</strong>
                            <small>@stop.Label</small>
                            <p>@stop.Reason</p>
                        </div>
                    </article>
                }
            </aside>
        </section>
    }
</section>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>
    <script>
        const plannerPoints = @routePointsJson;
        const plannerStops = @stopsJson;

        document.addEventListener("DOMContentLoaded", function () {
            const plannerForm = document.getElementById("walkPlannerForm");
            const latitudeInput = document.getElementById("plannerLatitude");
            const longitudeInput = document.getElementById("plannerLongitude");
            const locationStatus = document.getElementById("plannerLocationStatus");
            const locationButton = document.getElementById("usePlannerLocation");
            const distanceInput = document.getElementById("distanceKm");
            const styleInput = document.getElementById("walkStyle");
            const includeBinsInput = document.getElementById("includeBins");
            const includeParkInput = document.getElementById("includePark");
            const includeWaterInput = document.getElementById("includeWater");
            const includeDogFriendlyInput = document.getElementById("includeDogFriendly");
            const dogSelect = document.getElementById("dogId");
            const energySelect = document.getElementById("dogEnergy");

            document.querySelectorAll(".walk-planner-preset").forEach(button => {
                button.addEventListener("click", function () {
                    distanceInput.value = button.dataset.distance;
                    styleInput.value = button.dataset.style;
                    includeBinsInput.value = button.dataset.bins;
                    includeParkInput.value = button.dataset.park;
                    includeWaterInput.value = button.dataset.water;
                    includeDogFriendlyInput.value = button.dataset.dogFriendly;
                    plannerForm?.requestSubmit();
                });
            });

            dogSelect?.addEventListener("change", () => plannerForm?.requestSubmit());
            energySelect?.addEventListener("change", () => plannerForm?.requestSubmit());

            function requestPlannerLocation(source) {
                if (!navigator.geolocation || !locationStatus || !latitudeInput || !longitudeInput) {
                    if (locationStatus) {
                        locationStatus.textContent = "Brskalnik ne podpira GPS lokacije. Uporabljeno bo fallback območje.";
                    }
                    return;
                }

                if (locationButton) {
                    locationButton.disabled = true;
                }
                locationStatus.textContent = source === "auto" ? "Iščem tvojo lokacijo..." : "Osvežujem lokacijo...";

                navigator.geolocation.getCurrentPosition(
                    position => {
                        latitudeInput.value = position.coords.latitude.toFixed(6);
                        longitudeInput.value = position.coords.longitude.toFixed(6);
                        locationStatus.textContent = "GPS je aktiven. Predlog je iz tvoje lokacije.";
                        sessionStorage.setItem("doggydropPlannerGpsTried", "true");
                        plannerForm?.requestSubmit();
                    },
                    () => {
                        if (locationButton) {
                            locationButton.disabled = false;
                        }
                        sessionStorage.setItem("doggydropPlannerGpsTried", "true");
                        locationStatus.textContent = "GPS ni dovoljen. Uporabljen bo rezervni mestni predlog.";
                    },
                    { enableHighAccuracy: true, timeout: 9000, maximumAge: 60000 }
                );
            }

            if (locationButton) {
                locationButton.addEventListener("click", () => requestPlannerLocation("manual"));
            }

            if (!latitudeInput?.value && !longitudeInput?.value && sessionStorage.getItem("doggydropPlannerGpsTried") !== "true") {
                requestPlannerLocation("auto");
            }

            if (!plannerPoints.length || !document.getElementById("plannerMap")) {
                return;
            }

            const routePoints = plannerPoints.map(point => [point.Latitude ?? point.latitude, point.Longitude ?? point.longitude]);
            const map = L.map("plannerMap", { zoomControl: true }).setView(routePoints[0], 15);

            L.tileLayer("https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png", {
                subdomains: "abcd",
                maxZoom: 20,
                attribution: "&copy; OpenStreetMap contributors &copy; CARTO"
            }).addTo(map);

            const line = L.polyline(routePoints, { color: "#2f6d5f", weight: 6, opacity: 0.9 }).addTo(map);

            plannerStops.forEach(stop => {
                const lat = stop.Latitude ?? stop.latitude;
                const lng = stop.Longitude ?? stop.longitude;
                const label = stop.Label ?? stop.label;
                const name = stop.Name ?? stop.name;
                if (typeof lat !== "number" || typeof lng !== "number") {
                    return;
                }

                L.marker([lat, lng], { icon: buildPlannerIcon(stop.Type ?? stop.type) })
                    .addTo(map)
                    .bindPopup(`<strong>${escapeHtml(name)}</strong><br>${escapeHtml(label)}`);
            });

            map.fitBounds(line.getBounds().pad(0.2), { maxZoom: 16 });
        });

        function buildPlannerIcon(type) {
            const labels = {
                start: "S",
                finish: "C",
                bin: "B",
                park: "P",
                water: "W",
                cafe: "C",
                shop: "T"
            };

            return L.divIcon({
                className: "",
                html: `<span class="planner-marker planner-marker--${escapeHtml(type || "stop")}">${labels[type] || "."}</span>`,
                iconSize: [38, 38],
                iconAnchor: [19, 19],
                popupAnchor: [0, -18]
            });
        }

        function escapeHtml(value) {
            return String(value ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }
    </script>
}

<style>
    .walk-planner-hero {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 14px;
    }

    .walk-planner-form,
    .walk-planner-map-card,
    .walk-planner-stops,
    .walk-planner-nearby-bin {
        border: 1px solid rgba(31, 45, 41, 0.1);
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 12px 28px rgba(31, 45, 41, 0.08);
    }

    .walk-planner-form {
        display: grid;
        gap: 14px;
        margin-bottom: 14px;
        padding: 14px;
    }

    .walk-planner-toolbar {
        display: grid;
        grid-template-columns: minmax(150px, 1fr) minmax(120px, 0.7fr) minmax(220px, 1.2fr);
        gap: 10px;
        align-items: start;
    }

    .walk-planner-form div,
    .walk-planner-location {
        display: grid;
        gap: 6px;
    }

    .walk-planner-form label {
        color: #21342f;
        font-size: 0.82rem;
        font-weight: 900;
    }

    .walk-planner-form select,
    .walk-planner-form button {
        min-height: 42px;
        border-radius: 8px;
        font-weight: 850;
    }

    .walk-planner-form select {
        border: 1px solid rgba(31, 45, 41, 0.14);
        background: #ffffff;
        color: #21342f;
    }

    .walk-planner-location__button {
        border: 1px solid rgba(47, 109, 95, 0.18) !important;
        background: #eef7ed !important;
        color: #2f6d5f !important;
    }

    .walk-planner-location__button:disabled {
        opacity: 0.72;
    }

    #plannerLocationStatus {
        color: #65716d;
        font-size: 0.78rem;
        font-weight: 800;
        line-height: 1.25;
    }

    .walk-planner-presets {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 10px;
    }

    .walk-planner-preset {
        display: grid;
        align-content: start;
        gap: 6px;
        min-height: 136px;
        padding: 14px;
        border: 1px solid rgba(47, 109, 95, 0.15);
        border-radius: 8px;
        background: #f7faf5;
        color: #21342f;
        text-align: left;
        cursor: pointer;
    }

    .walk-planner-preset.is-active {
        border-color: #2f6d5f;
        background: #e7f3ed;
        box-shadow: inset 0 0 0 2px rgba(47, 109, 95, 0.12);
    }

    .walk-planner-preset strong {
        font-size: 1rem;
        font-weight: 950;
    }

    .walk-planner-preset span {
        color: #65716d;
        font-size: 0.84rem;
        line-height: 1.25;
    }

    .walk-planner-preset em {
        align-self: end;
        color: #2f6d5f;
        font-style: normal;
        font-weight: 950;
    }

    .walk-planner-advanced summary {
        color: #2f6d5f;
        cursor: pointer;
        font-weight: 900;
    }

    .walk-planner-advanced__grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 10px;
        align-items: end;
        padding-top: 10px;
    }

    .walk-planner-advanced button {
        border: 0;
        background: #2f6d5f;
        color: #ffffff;
        padding: 0 16px;
    }

    .walk-planner-nearby-bin {
        display: grid;
        gap: 3px;
        margin-bottom: 14px;
        padding: 12px 14px;
        background: #fff8e8;
        color: #4b3b20;
    }

    .walk-planner-nearby-bin strong {
        font-weight: 950;
    }

    .walk-planner-nearby-bin span {
        color: #746850;
        font-weight: 800;
    }

    .walk-planner-layout {
        display: grid;
        grid-template-columns: minmax(0, 760px) minmax(280px, 340px);
        justify-content: center;
        gap: 14px;
    }

    .walk-planner-map-card,
    .walk-planner-stops {
        padding: 14px;
    }

    .walk-planner-summary {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 12px;
    }

    .walk-planner-summary h2,
    .walk-planner-stops h2 {
        margin: 0;
        font-size: 1.1rem;
        font-weight: 950;
    }

    .walk-planner-summary p {
        margin: 4px 0 0;
        color: #65716d;
    }

    .walk-planner-summary strong,
    .walk-planner-summary span {
        display: block;
        color: #2f6d5f;
        font-weight: 950;
        text-align: right;
        white-space: nowrap;
    }

    .walk-planner-map-frame {
        overflow: hidden;
        border-radius: 8px;
        border: 1px solid rgba(31, 45, 41, 0.1);
        background: #eaf4ea;
        aspect-ratio: 4 / 3;
        max-height: 560px;
    }

    #plannerMap {
        width: 100%;
        height: 100%;
        min-height: 0;
    }

    .walk-planner-start {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 8px;
        margin-top: 12px;
    }

    .walk-planner-start button,
    .walk-planner-start a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 42px;
        padding: 10px 16px;
        border: 0;
        border-radius: 999px;
        background: #2f6d5f;
        color: #ffffff;
        font-weight: 900;
        text-decoration: none;
    }

    .walk-planner-start button {
        width: 100%;
    }

    .walk-planner-start__secondary {
        border: 1px solid rgba(47, 109, 95, 0.18) !important;
        background: #eef7ed !important;
        color: #2f6d5f !important;
    }

    .planner-marker {
        display: grid;
        width: 38px;
        height: 38px;
        place-items: center;
        border: 3px solid #ffffff;
        border-radius: 14px;
        background: #2f6d5f;
        box-shadow: 0 10px 20px rgba(31, 45, 41, 0.25);
        color: #ffffff;
        font-size: 0.8rem;
        font-weight: 950;
    }

    .planner-marker--bin { background: #2f6d5f; }
    .planner-marker--park { background: #467b42; }
    .planner-marker--water { background: #2f7da5; }
    .planner-marker--cafe,
    .planner-marker--shop { background: #b66b2f; }
    .planner-marker--start,
    .planner-marker--finish { background: #21342f; }

    .walk-planner-stops {
        display: grid;
        align-content: start;
        gap: 10px;
    }

    .walk-planner-stops article {
        display: grid;
        grid-template-columns: 34px minmax(0, 1fr);
        gap: 10px;
        padding: 10px;
        border: 1px solid rgba(31, 45, 41, 0.08);
        border-radius: 8px;
        background: #f8faf7;
    }

    .walk-planner-stops article > span {
        display: grid;
        width: 34px;
        height: 34px;
        place-items: center;
        border-radius: 999px;
        background: #2f6d5f;
        color: #ffffff;
        font-weight: 950;
    }

    .walk-planner-stops strong,
    .walk-planner-stops small {
        display: block;
    }

    .walk-planner-stops strong {
        color: #21342f;
        font-weight: 950;
    }

    .walk-planner-stops small {
        color: #2f6d5f;
        font-weight: 850;
    }

    .walk-planner-stops p {
        margin: 4px 0 0;
        color: #65716d;
        font-size: 0.86rem;
        line-height: 1.35;
    }

    @@media (max-width: 1100px) {
        .walk-planner-presets {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 900px) {
        .walk-planner-layout,
        .walk-planner-toolbar,
        .walk-planner-start,
        .walk-planner-advanced__grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 575.98px) {
        .walk-planner-hero,
        .walk-planner-summary {
            align-items: stretch;
            flex-direction: column;
        }

        .walk-planner-presets {
            grid-template-columns: 1fr;
        }

        .walk-planner-preset {
            min-height: 112px;
        }

        .walk-planner-summary strong,
        .walk-planner-summary span {
            text-align: left;
        }

        #plannerMap {
            min-height: 0;
        }

        .walk-planner-map-frame {
            aspect-ratio: 1 / 1;
            max-height: 420px;
        }
    }
</style>
