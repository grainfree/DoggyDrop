@model DoggyDrop.ViewModels.WalkPlannerViewModel
@using System.Globalization
@using System.Text.Json

@{
    ViewData["Title"] = "Planer sprehoda";
    var routePointsJson = Html.Raw(JsonSerializer.Serialize(Model.Route?.RoutePoints ?? []));
    var stopsJson = Html.Raw(JsonSerializer.Serialize(Model.Route?.Stops ?? []));
    var latitudeValue = Model.Latitude?.ToString("0.######", CultureInfo.InvariantCulture) ?? string.Empty;
    var longitudeValue = Model.Longitude?.ToString("0.######", CultureInfo.InvariantCulture) ?? string.Empty;
    var binStop = Model.Route?.Stops.FirstOrDefault(stop => stop.Type == "bin");
    var selectedDog = Model.Dogs.FirstOrDefault(dog => dog.Id == Model.SelectedDogId) ?? Model.Dogs.FirstOrDefault();
    var selectedPreset = Model.Presets.FirstOrDefault(preset =>
        Math.Abs(Model.TargetDistanceKm - preset.DistanceKm) < 0.05
        && string.Equals(Model.WalkStyle, preset.WalkStyle, StringComparison.OrdinalIgnoreCase))
        ?? Model.Presets.FirstOrDefault();
    var showDogChooser = Model.Dogs.Count != 1 || selectedDog == null;
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
          integrity="sha256-p4NxAoJBhIINfQXh6ULpR5txR9wra5I3BcVsTPY1p3A="
          crossorigin="" />
}

<section class="app-page walk-planner-page">
    <header class="app-page__header walk-planner-hero">
        <div>
            <h1 class="app-page__title">Planer sprehoda</h1>
            <p class="app-page__lead">Izberi hiter predlog. GPS je privzet, koši v bližini pa se samodejno vključijo v pot.</p>
        </div>
        <a class="btn btn-outline-secondary rounded-pill" asp-controller="Walks" asp-action="Index">Sprehodi</a>
    </header>

    <form class="walk-planner-form walk-planner-form--quick" asp-controller="Walks" asp-action="Planner" method="get" id="walkPlannerForm">
        <input type="hidden" id="plannerLatitude" name="latitude" value="@latitudeValue" />
        <input type="hidden" id="plannerLongitude" name="longitude" value="@longitudeValue" />
        <input type="hidden" id="distanceKm" name="distanceKm" value="@Model.TargetDistanceKm.ToString(CultureInfo.InvariantCulture)" />
        <input type="hidden" id="walkStyle" name="walkStyle" value="@Model.WalkStyle" />
        <input type="hidden" id="includeBins" name="includeBins" value="@Model.IncludeBins.ToString().ToLowerInvariant()" />
        <input type="hidden" id="includePark" name="includePark" value="@Model.IncludePark.ToString().ToLowerInvariant()" />
        <input type="hidden" id="includeWater" name="includeWater" value="@Model.IncludeWater.ToString().ToLowerInvariant()" />
        <input type="hidden" id="includeDogFriendly" name="includeDogFriendly" value="@Model.IncludeDogFriendly.ToString().ToLowerInvariant()" />
        <input type="hidden" id="dogEnergy" name="dogEnergy" value="auto" />
        <input type="hidden" id="area" name="area" value="@Model.AreaKey" />
        @if (Model.Dogs.Count == 1 && selectedDog != null)
        {
            <input type="hidden" id="dogId" name="dogId" value="@selectedDog.Id" />
        }

        <div class="walk-planner-toolbar">
            @if (showDogChooser)
            {
                <div class="walk-planner-dogs">
                    @if (Model.Dogs.Count == 0)
                    {
                        <a class="walk-planner-dog-chip walk-planner-dog-chip--empty" asp-controller="Dogs" asp-action="Create">Dodaj psa</a>
                    }
                    else
                    {
                        <div class="walk-planner-dog-options" role="radiogroup" aria-label="Izberi psa">
                            @foreach (var dog in Model.Dogs)
                            {
                                var isSelected = Model.SelectedDogId == dog.Id || (!Model.SelectedDogId.HasValue && dog.Id == selectedDog?.Id);
                                <label class="walk-planner-dog-chip @(isSelected ? "is-active" : "")">
                                    <input type="radio" name="dogId" value="@dog.Id" checked="@isSelected" />
                                    <span>@dog.Name</span>
                                </label>
                            }
                        </div>
                    }
                </div>
            }
            <div class="walk-planner-location" hidden>
                <button type="button" id="usePlannerLocation" class="walk-planner-location__button">Moja lokacija</button>
            </div>
            <span id="plannerLocationStatus" class="walk-planner-location-alert" hidden>@(Model.UsesCurrentLocation ? "" : "Dovoli lokacijo za predlog iz tvoje bližine.")</span>
        </div>

        <div class="walk-planner-presets" aria-label="Hitri predlogi sprehoda">
            @foreach (var preset in Model.Presets)
            {
                var isActive = Math.Abs(Model.TargetDistanceKm - preset.DistanceKm) < 0.05
                    && string.Equals(Model.WalkStyle, preset.WalkStyle, StringComparison.OrdinalIgnoreCase);
                var presetIcon = preset.WalkStyle switch
                {
                    "quick" => "bi-lightning-charge-fill",
                    "park" => "bi-tree-fill",
                    "city" => "bi-buildings-fill",
                    "long" => "bi-compass-fill",
                    _ => "bi-arrow-repeat"
                };
                <button type="button"
                        class="walk-planner-preset @(isActive ? "is-active" : "")"
                        title="@($"{preset.Title} · {preset.DistanceKm:0.#} km")"
                        aria-label="@($"{preset.Title}, {preset.DistanceKm:0.#} km")"
                        data-distance="@preset.DistanceKm.ToString(CultureInfo.InvariantCulture)"
                        data-style="@preset.WalkStyle"
                        data-title="@preset.Title"
                        data-bins="@preset.IncludeBins.ToString().ToLowerInvariant()"
                        data-park="@preset.IncludePark.ToString().ToLowerInvariant()"
                        data-water="@preset.IncludeWater.ToString().ToLowerInvariant()"
                        data-dog-friendly="@preset.IncludeDogFriendly.ToString().ToLowerInvariant()">
                    <i class="bi @presetIcon" aria-hidden="true"></i>
                </button>
            }
        </div>
    </form>

    @if (binStop != null)
    {
        <aside class="walk-planner-nearby-bin">
            <strong>Koš je vključen v pot</strong>
            <span>@binStop.Name je na predlagani trasi, če ga med sprehodom potrebuješ.</span>
        </aside>
    }

    @if (Model.Route != null)
    {
        <section class="walk-planner-layout">
            <article class="walk-planner-map-card">
                <div class="walk-planner-summary">
                    <div>
                        <div class="walk-planner-selected-purpose" id="selectedWalkPurpose">
                            <span>Namen</span>
                            <strong>@(selectedPreset?.Title ?? "Sprehod")</strong>
                            <em>@Model.TargetDistanceKm.ToString("0.#") km</em>
                        </div>
                        <p>@Model.Route.Summary</p>
                        @if (binStop != null)
                        {
                            <p class="walk-planner-bin-pill"><i class="bi bi-trash3-fill" aria-hidden="true"></i> Kos na poti: @binStop.Name</p>
                        }
                    </div>
                    <div>
                        <strong>@Model.Route.EstimatedDistanceKm.ToString("0.0") km</strong>
                        <span>~@Model.Route.EstimatedMinutes min</span>
                    </div>
                </div>
                <div class="walk-planner-map-frame">
                    <div id="plannerRouteMap" class="walk-planner-route-map" role="img" aria-label="Predvidena pot sprehoda"></div>
                    <span class="walk-planner-map-note">Predogled na zemljevidu</span>
                </div>
                <div class="walk-planner-start">
                    <form asp-controller="Walks" asp-action="SavePlan" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="dogId" value="@Model.SelectedDogId" />
                        <input type="hidden" name="area" value="@Model.AreaKey" />
                        <input type="hidden" name="latitude" value="@latitudeValue" />
                        <input type="hidden" name="longitude" value="@longitudeValue" />
                        <input type="hidden" name="distanceKm" value="@Model.TargetDistanceKm.ToString(CultureInfo.InvariantCulture)" />
                        <input type="hidden" name="walkStyle" value="@Model.WalkStyle" />
                        <input type="hidden" name="dogEnergy" value="auto" />
                        <input type="hidden" name="includeBins" value="@Model.IncludeBins.ToString().ToLowerInvariant()" />
                        <input type="hidden" name="includePark" value="@Model.IncludePark.ToString().ToLowerInvariant()" />
                        <input type="hidden" name="includeWater" value="@Model.IncludeWater.ToString().ToLowerInvariant()" />
                        <input type="hidden" name="includeDogFriendly" value="@Model.IncludeDogFriendly.ToString().ToLowerInvariant()" />
                        <button type="submit" class="walk-planner-start__secondary">
                            @(Model.Route.SavedPlanId.HasValue ? "Shrani kot nov plan" : "Shrani plan")
                        </button>
                    </form>
                    @if (Model.SelectedDogId.HasValue)
                    {
                        <form asp-controller="Walks" asp-action="StartPlanned" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="dogId" value="@Model.SelectedDogId.Value" />
                            <input type="hidden" name="area" value="@Model.AreaKey" />
                            <input type="hidden" name="latitude" value="@latitudeValue" />
                            <input type="hidden" name="longitude" value="@longitudeValue" />
                            <input type="hidden" name="distanceKm" value="@Model.TargetDistanceKm.ToString(CultureInfo.InvariantCulture)" />
                            <input type="hidden" name="walkStyle" value="@Model.WalkStyle" />
                            <input type="hidden" name="dogEnergy" value="auto" />
                            <input type="hidden" name="includeBins" value="@Model.IncludeBins.ToString().ToLowerInvariant()" />
                            <input type="hidden" name="includePark" value="@Model.IncludePark.ToString().ToLowerInvariant()" />
                            <input type="hidden" name="includeWater" value="@Model.IncludeWater.ToString().ToLowerInvariant()" />
                            <input type="hidden" name="includeDogFriendly" value="@Model.IncludeDogFriendly.ToString().ToLowerInvariant()" />
                            <button type="submit">Začni ta sprehod</button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Dogs" asp-action="Create">Dodaj psa za začetek sprehoda</a>
                    }
                </div>
            </article>

            <aside class="walk-planner-stops">
                <h2>Postanki</h2>
                @foreach (var stop in Model.Route.Stops)
                {
                    <article>
                        <span>@stop.Order</span>
                        <div>
                            <strong>@stop.Name</strong>
                            <small>@stop.Label</small>
                            <p>@stop.Reason</p>
                        </div>
                    </article>
                }
            </aside>
        </section>
    }
</section>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
            integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
            crossorigin=""></script>
    <script>
        const plannerPoints = @routePointsJson;
        const plannerStops = @stopsJson;

        document.addEventListener("DOMContentLoaded", function () {
            const plannerForm = document.getElementById("walkPlannerForm");
            const latitudeInput = document.getElementById("plannerLatitude");
            const longitudeInput = document.getElementById("plannerLongitude");
            const locationStatus = document.getElementById("plannerLocationStatus");
            const locationButton = document.getElementById("usePlannerLocation");
            const distanceInput = document.getElementById("distanceKm");
            const styleInput = document.getElementById("walkStyle");
            const includeBinsInput = document.getElementById("includeBins");
            const includeParkInput = document.getElementById("includePark");
            const includeWaterInput = document.getElementById("includeWater");
            const includeDogFriendlyInput = document.getElementById("includeDogFriendly");
            const selectedWalkPurpose = document.getElementById("selectedWalkPurpose");
            const storedLocation = readStoredPlannerLocation();

            document.querySelectorAll(".walk-planner-preset").forEach(button => {
                button.addEventListener("click", function () {
                    document.querySelectorAll(".walk-planner-preset").forEach(item => item.classList.remove("is-active"));
                    button.classList.add("is-active");
                    plannerForm?.classList.add("is-loading");
                    if (selectedWalkPurpose) {
                        const title = button.dataset.title || button.getAttribute("aria-label") || "Sprehod";
                        const distance = button.dataset.distance || "";
                        selectedWalkPurpose.querySelector("strong").textContent = title;
                        selectedWalkPurpose.querySelector("em").textContent = distance ? `${Number(distance).toLocaleString("sl-SI", { maximumFractionDigits: 1 })} km` : "";
                    }
                    distanceInput.value = button.dataset.distance;
                    styleInput.value = button.dataset.style;
                    includeBinsInput.value = button.dataset.bins;
                    includeParkInput.value = button.dataset.park;
                    includeWaterInput.value = button.dataset.water;
                    includeDogFriendlyInput.value = button.dataset.dogFriendly;
                    requestAnimationFrame(() => plannerForm?.requestSubmit());
                });
            });

            document.querySelectorAll("input[name='dogId'][type='radio']").forEach(input => {
                input.addEventListener("change", () => {
                    document.querySelectorAll(".walk-planner-dog-chip").forEach(chip => {
                        const radio = chip.querySelector("input");
                        chip.classList.toggle("is-active", radio?.checked === true);
                    });
                    plannerForm?.requestSubmit();
                });
            });

            function requestPlannerLocation(source) {
                if (!navigator.geolocation || !locationStatus || !latitudeInput || !longitudeInput) {
                    if (locationStatus) {
                        locationStatus.textContent = "Lokacija ni dovoljena, zato predlog ni iz tvoje bližine.";
                        locationStatus.hidden = false;
                    }
                    return;
                }

                if (locationButton) {
                    locationButton.disabled = true;
                }
                locationStatus.textContent = "";
                locationStatus.hidden = true;

                navigator.geolocation.getCurrentPosition(
                    position => {
                        latitudeInput.value = position.coords.latitude.toFixed(6);
                        longitudeInput.value = position.coords.longitude.toFixed(6);
                        locationStatus.textContent = "";
                        locationStatus.hidden = true;
                        localStorage.setItem("doggydropPlannerLocation", JSON.stringify({
                            latitude: latitudeInput.value,
                            longitude: longitudeInput.value,
                            savedAt: Date.now()
                        }));
                        sessionStorage.setItem("doggydropPlannerGpsTried", "true");
                        plannerForm?.requestSubmit();
                    },
                    () => {
                        if (locationButton) {
                            locationButton.disabled = false;
                        }
                        sessionStorage.setItem("doggydropPlannerGpsTried", "true");
                        locationStatus.textContent = "Lokacija ni dovoljena, zato predlog ni iz tvoje bližine.";
                        locationStatus.hidden = false;
                    },
                    { enableHighAccuracy: true, timeout: 9000, maximumAge: 60000 }
                );
            }

            if (locationButton) {
                locationButton.addEventListener("click", () => requestPlannerLocation("manual"));
            }

            if (!latitudeInput?.value && !longitudeInput?.value && storedLocation) {
                latitudeInput.value = storedLocation.latitude;
                longitudeInput.value = storedLocation.longitude;
                if (locationStatus) {
                    locationStatus.textContent = "";
                    locationStatus.hidden = true;
                }
                plannerForm?.requestSubmit();
                return;
            }

            if (!latitudeInput?.value && !longitudeInput?.value && sessionStorage.getItem("doggydropPlannerGpsTried") !== "true") {
                requestPlannerLocation("auto");
            }

            drawPlannerRoutePreview();
        });

        function drawPlannerRoutePreview() {
            const mapElement = document.getElementById("plannerRouteMap");
            if ((!plannerPoints.length && !plannerStops.length) || !mapElement || typeof L === "undefined") {
                return;
            }

            const routePoints = plannerPoints
                .map(readCoordinate)
                .filter(Boolean);
            const stopPoints = plannerStops
                .map(stop => ({ ...stop, point: readCoordinate(stop) }))
                .filter(stop => stop.point);
            const center = routePoints[0] ?? stopPoints[0]?.point;
            const previewRoutePoints = routePoints.length >= 4
                ? routePoints
                : buildPreviewLoop(center, readTargetDistanceKm(), stopPoints.map(stop => stop.point));
            const allPoints = previewRoutePoints.concat(stopPoints.map(stop => stop.point));
            if (allPoints.length === 0) {
                return;
            }

            const map = L.map(mapElement, {
                zoomControl: false,
                attributionControl: true,
                scrollWheelZoom: false,
                tap: true
            }).setView([center.lat, center.lng], 15);

            L.tileLayer("https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png", {
                maxZoom: 20,
                attribution: '&copy; OpenStreetMap &copy; CARTO'
            }).addTo(map);

            const latLngs = previewRoutePoints.map(point => [point.lat, point.lng]);
            if (latLngs.length > 1) {
                const routeHalo = L.polyline(latLngs, {
                    color: "#ffffff",
                    weight: 11,
                    opacity: 0.92,
                    lineCap: "round",
                    lineJoin: "round"
                }).addTo(map);

                const routeLine = L.polyline(latLngs, {
                    color: "#24695a",
                    weight: 6,
                    opacity: 0.94,
                    lineCap: "round",
                    lineJoin: "round"
                }).addTo(map);

                const routeDash = L.polyline(latLngs, {
                    color: "#f3b85b",
                    weight: 2,
                    opacity: 0.9,
                    dashArray: "5 12",
                    lineCap: "round"
                }).addTo(map);

                routeHalo.bringToFront();
                routeLine.bringToFront();
                routeDash.bringToFront();
            }

            stopPoints.forEach(stop => {
                const type = stop.Type ?? stop.type ?? "stop";
                const order = stop.Order ?? stop.order ?? "";
                const name = stop.Name ?? stop.name ?? "Postanek";
                const label = stop.Label ?? stop.label ?? "";
                const icon = L.divIcon({
                    className: "",
                    iconSize: [34, 34],
                    iconAnchor: [17, 17],
                    html: `<span class="walk-planner-leaflet-stop walk-planner-leaflet-stop--${escapeHtml(type)}">${escapeHtml(order)}</span>`
                });
                L.marker([stop.point.lat, stop.point.lng], { icon })
                    .bindPopup(`<strong>${escapeHtml(name)}</strong><br><span>${escapeHtml(label)}</span>`)
                    .addTo(map);
            });

            const bounds = L.latLngBounds(allPoints.map(point => [point.lat, point.lng]));
            const fitMap = () => {
                map.invalidateSize({ pan: false });
                map.fitBounds(bounds, { padding: [24, 24], maxZoom: 16 });
                drawRouteSketchOverlay(mapElement, map, previewRoutePoints);
            };

            requestAnimationFrame(fitMap);
            setTimeout(fitMap, 120);
            setTimeout(fitMap, 450);
            window.addEventListener("load", fitMap, { once: true });
            window.addEventListener("resize", fitMap);

            if ("ResizeObserver" in window) {
                const resizeObserver = new ResizeObserver(fitMap);
                resizeObserver.observe(mapElement);
            }
        }

        function readTargetDistanceKm() {
            const value = Number(document.getElementById("distanceKm")?.value || "3");
            return Number.isFinite(value) ? Math.max(1, Math.min(value, 8)) : 3;
        }

        function drawRouteSketchOverlay(mapElement, map, points) {
            const frame = mapElement.closest(".walk-planner-map-frame") ?? mapElement;
            frame.querySelector(".walk-planner-route-sketch")?.remove();
            if (!points || points.length < 2) {
                return;
            }

            const width = mapElement.clientWidth || frame.clientWidth;
            const height = mapElement.clientHeight || frame.clientHeight;
            if (!width || !height) {
                return;
            }

            const projected = points
                .map(point => map.latLngToContainerPoint([point.lat, point.lng]))
                .filter(point => Number.isFinite(point.x) && Number.isFinite(point.y));
            if (projected.length < 2) {
                return;
            }

            const routePath = projected
                .map((point, index) => `${index === 0 ? "M" : "L"} ${point.x.toFixed(1)} ${point.y.toFixed(1)}`)
                .join(" ");
            const svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
            svg.setAttribute("class", "walk-planner-route-sketch");
            svg.setAttribute("viewBox", `0 0 ${width} ${height}`);
            svg.setAttribute("aria-hidden", "true");
            svg.innerHTML = `
                <path class="walk-planner-route-sketch__halo" d="${routePath}" />
                <path class="walk-planner-route-sketch__line" d="${routePath}" />
                <path class="walk-planner-route-sketch__dash" d="${routePath}" />
            `;
            frame.appendChild(svg);
        }

        function buildPreviewLoop(center, distanceKm, stops) {
            if (!center) {
                return [];
            }

            const radiusKm = Math.max(0.18, distanceKm / (2 * Math.PI));
            const latDelta = radiusKm / 111;
            const lngDelta = radiusKm / (111 * Math.cos(center.lat * Math.PI / 180));
            const loop = [
                { lat: center.lat, lng: center.lng },
                { lat: center.lat + latDelta * 0.82, lng: center.lng + lngDelta * 0.38 },
                { lat: center.lat + latDelta * 0.38, lng: center.lng + lngDelta * 0.95 },
                { lat: center.lat - latDelta * 0.42, lng: center.lng + lngDelta * 0.82 },
                { lat: center.lat - latDelta * 0.88, lng: center.lng + lngDelta * 0.06 },
                { lat: center.lat - latDelta * 0.36, lng: center.lng - lngDelta * 0.84 },
                { lat: center.lat + latDelta * 0.48, lng: center.lng - lngDelta * 0.74 },
                { lat: center.lat, lng: center.lng }
            ];

            stops
                .filter(Boolean)
                .filter(point => Math.abs(point.lat - center.lat) > 0.00005 || Math.abs(point.lng - center.lng) > 0.00005)
                .slice(0, 2)
                .forEach((point, index) => loop.splice(index + 2, 0, point));

            return loop;
        }

        function readStoredPlannerLocation() {
            try {
                const raw = localStorage.getItem("doggydropPlannerLocation");
                if (!raw) {
                    return null;
                }
                const parsed = JSON.parse(raw);
                if (!parsed?.latitude || !parsed?.longitude || Date.now() - Number(parsed.savedAt ?? 0) > 12 * 60 * 60 * 1000) {
                    return null;
                }
                return parsed;
            } catch {
                return null;
            }
        }

        function readCoordinate(item) {
            const lat = item?.Latitude ?? item?.latitude;
            const lng = item?.Longitude ?? item?.longitude;
            const parsedLat = Number(lat);
            const parsedLng = Number(lng);
            return Number.isFinite(parsedLat) && Number.isFinite(parsedLng)
                ? { lat: parsedLat, lng: parsedLng }
                : null;
        }

        function escapeHtml(value) {
            return String(value ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }
    </script>
}

<style>
    .walk-planner-page {
        width: 100%;
        max-width: 980px;
        margin: 0 auto;
        padding-bottom: 94px;
    }

    .walk-planner-hero {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 10px;
        margin-bottom: 10px;
    }

    .walk-planner-hero .app-page__title {
        font-size: clamp(1.55rem, 3vw, 2.15rem);
    }

    .walk-planner-hero .app-page__lead {
        display: none;
    }

    .walk-planner-form,
    .walk-planner-map-card,
    .walk-planner-stops,
    .walk-planner-nearby-bin {
        border: 1px solid rgba(31, 45, 41, 0.1);
        border-radius: 8px;
        background: #ffffff;
        box-shadow: 0 12px 28px rgba(31, 45, 41, 0.08);
    }

    .walk-planner-form {
        display: grid;
        gap: 8px;
        margin-bottom: 8px;
        padding: 10px;
    }

    .walk-planner-form.is-loading .walk-planner-presets {
        opacity: 0.82;
        pointer-events: none;
    }

    .walk-planner-toolbar {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 12px;
        align-items: center;
    }

    .walk-planner-form div,
    .walk-planner-location {
        display: grid;
        gap: 6px;
    }

    .walk-planner-form label {
        color: #21342f;
        font-size: 0.82rem;
        font-weight: 900;
    }

    .walk-planner-dogs {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
    }

    .walk-planner-dogs > span {
        display: none;
        color: #21342f;
        font-size: 0.82rem;
        font-weight: 900;
    }

    .walk-planner-dog-options {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .walk-planner-dog-chip {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 40px;
        width: fit-content;
        max-width: 100%;
        padding: 10px 14px;
